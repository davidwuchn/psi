-- allium: 1

-- tool-output-rendering.allium
-- Interactive rendering contract for tool-call output.

use "./tools/runtime.allium" as runtime

value RenderCapabilities {
    images: none | kitty | iterm2 | inline
}

value ToolImage {
    mime_type: String
    data: String
    width: Integer?
    height: Integer?
}

value ToolOutputDisplayDetails {
    truncation: runtime/ToolOutputTruncation?
    full_output_path: String?
    diff: String?
    first_changed_line: Integer?
}

value ToolOutputPayload {
    text: String
    images: Set<ToolImage>
    is_error: Boolean
    details: ToolOutputDisplayDetails?
}

value ToolRendererRegistration {
    tool_name: String
    has_render_call: Boolean
    has_render_result: Boolean
}

entity ToolOutputView {
    tool_call_id: String
    tool_name: String
    status: pending | running | success | error

    expanded: Boolean
    show_images: Boolean

    args: String?
    parsed_args: Map?
    output: ToolOutputPayload?
    capabilities: RenderCapabilities?

    header: String
    visible_text: String
    warnings: Set<String>
    background: pending | success | error

    inline_images: Set<ToolImage>
    image_fallback_count: Integer
}

config {
    expand_tools_keybinding: String = "ctrl+o"
    missing_primary_arg_placeholder: String = "…"

    read_preview_lines: Integer = 10
    write_preview_lines: Integer = 10
    bash_preview_visual_lines: Integer = 5
}

rule BuiltInRendererUsedByDefault {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.tool_name in {"read", "bash", "edit", "write"}
    requires: registration = null or (registration.has_render_call = false and registration.has_render_result = false)

    ensures: BuiltInRendererSelected(view)
}

rule CustomRendererOverridesBuiltIn {
    when: ToolOutputRenderRequested(view, registration)
    requires: registration != null
    requires: registration.has_render_call = true or registration.has_render_result = true

    ensures: CustomRendererSelected(view, registration)
}

rule CustomRendererFailureFallsBackSafely {
    when: CustomRendererSelected(view, registration)
    requires: RendererThrows(view, registration)

    ensures: FallbackRendererUsed(view)
    ensures: view.header != "" or view.visible_text != ""
}

rule HeadersIncludePrimaryArgument {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.tool_name in {"read", "bash", "edit", "write"}

    ensures:
        if PrimaryArgumentValue(view) = null:
            Contains(view.header, config.missing_primary_arg_placeholder)
        else:
            Contains(view.header, DisplayPrimaryArgument(view))
}

rule InvalidArgumentTypeShowsMarker {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.args != null
    requires: not ArgumentsParseToObject(view)

    ensures: Contains(view.header, "[invalid arg]")
}

rule BackgroundReflectsExecutionState {
    when: ToolOutputRenderRequested(view, registration)

    ensures:
        if view.status in {pending, running}:
            view.background = pending
        else if view.status = error:
            view.background = error
        else:
            view.background = success
}

rule ExpandedShowsCompleteText {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.expanded = true

    ensures: view.visible_text = view.output.text
}

rule CollapsedPreviewsAreBounded {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.expanded = false

    ensures:
        if view.tool_name = "read":
            view.visible_text = FirstLinesText(view.output.text, config.read_preview_lines)
        else if view.tool_name = "write":
            view.visible_text = FirstLinesText(view.output.text, config.write_preview_lines)
        else if view.tool_name = "bash":
            view.visible_text = LastVisualLinesText(view.output.text, config.bash_preview_visual_lines)
        else:
            view.visible_text = view.output.text
}

rule ErrorOutputStyledAsError {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.output.is_error = true

    ensures: ErrorStyleApplied(view.visible_text)
}

rule TruncationWarningsShownWhenPresent {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.output.details != null
    requires: view.output.details.truncation != null
    requires: view.output.details.truncation.truncated = true

    ensures: view.warnings = view.warnings + {"Truncated"}
}

rule FullOutputPathShownWhenAvailable {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.output.details != null
    requires: view.output.details.full_output_path != null

    ensures: view.warnings = view.warnings + {"Full output: " + view.output.details.full_output_path}
}

rule InlineImagesShownWhenEnabledAndSupported {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.output.images.count > 0
    requires: view.show_images = true
    requires: view.capabilities.images != none

    ensures: view.inline_images = view.output.images
    ensures: view.image_fallback_count = 0
}

rule ImageFallbackShownWhenInlineUnavailable {
    when: ToolOutputRenderRequested(view, registration)
    requires: view.output != null
    requires: view.output.images.count > 0
    requires: view.show_images = false or view.capabilities.images = none

    ensures: view.inline_images = {}
    ensures: view.image_fallback_count = view.output.images.count
}

surface ToolOutputRenderer {
    facing caller: InteractiveRenderer | ExtensionRenderer

    provides:
        ToolOutputRenderRequested(view, registration)

    exposes:
        ToolOutputView

    @guidance
        -- Shared renderer contract for interactive UIs.
        -- Expansion is presentation-only and does not mutate tool payloads.
        -- Compact mode should disclose hidden output with an expansion hint.
}
