-- allium: 1

-- agent.allium
-- Stateful LLM agent with streaming, tools, steering, and follow-up.

external entity Model {
    provider: String
    id: String
    api: String
}

value TextContent {
    type: text
    text: String
}

value ImageContent {
    type: image
    data: String
    mime_type: String
}

value ThinkingContent {
    type: thinking
    thinking: String
}

value ToolCallContent {
    type: tool_call
    id: String
    name: String
    arguments: String
}

value UsageStats {
    input: Integer
    output: Integer
    cache_read: Integer
    cache_write: Integer
    total_tokens: Integer
}

entity AgentMessage {
    role: user | assistant | tool_result | custom
    timestamp: Timestamp
}

entity AssistantMessage {
    role: assistant
    timestamp: Timestamp
    content: Set<TextContent | ThinkingContent | ToolCallContent>
    model: String
    provider: String
    stop_reason: stop | length | tool_use | aborted | error
    usage: UsageStats?
    error_message: String?
}

entity UserMessage {
    role: user
    timestamp: Timestamp
    content: Set<TextContent | ImageContent>
}

entity ToolResultMessage {
    role: tool_result
    timestamp: Timestamp
    tool_call_id: String
    tool_name: String
    content: Set<TextContent | ImageContent>
    is_error: Boolean
}

entity AgentTool {
    name: String
    label: String
    description: String
    parameters: String
}

entity AgentState {
    system_prompt: String
    model: Model
    thinking_level: off | minimal | low | medium | high | xhigh
    tools: Set<AgentTool>
    messages: Set<AgentMessage>

    is_streaming: Boolean
    stream_message: AgentMessage?
    pending_tool_calls: Set<String>
    error: String?

    steering_queue: Set<String>
    follow_up_queue: Set<String>

    steering_mode: all | one_at_a_time
    follow_up_mode: all | one_at_a_time

    is_idle: not is_streaming
    has_queued_messages: steering_queue.count > 0 or follow_up_queue.count > 0
}

config {
    default_model_provider: String = "google"
    default_model_id: String = "gemini-2.5-flash-lite-preview-06-17"
    default_thinking_level: off | minimal | low | medium | high | xhigh = off
    default_steering_mode: all | one_at_a_time = one_at_a_time
    default_follow_up_mode: all | one_at_a_time = one_at_a_time
}

rule CreateAgent {
    when: CreateAgent(initial_state)

    ensures: AgentState.created(
        system_prompt: initial_state.system_prompt ?? "",
        model: initial_state.model ?? Model{provider: config.default_model_provider, id: config.default_model_id, api: "default"},
        thinking_level: initial_state.thinking_level ?? config.default_thinking_level,
        tools: initial_state.tools ?? {},
        messages: initial_state.messages ?? {},
        is_streaming: false,
        stream_message: null,
        pending_tool_calls: {},
        error: null,
        steering_queue: {},
        follow_up_queue: {},
        steering_mode: config.default_steering_mode,
        follow_up_mode: config.default_follow_up_mode
    )
}

rule ResetAgent {
    when: ResetAgent(agent)

    ensures: agent.messages = {}
    ensures: agent.is_streaming = false
    ensures: agent.stream_message = null
    ensures: agent.pending_tool_calls = {}
    ensures: agent.error = null
    ensures: agent.steering_queue = {}
    ensures: agent.follow_up_queue = {}
}

rule SetSystemPrompt {
    when: SetSystemPrompt(agent, prompt)
    ensures: agent.system_prompt = prompt
}

rule SetModel {
    when: SetModel(agent, model)
    ensures: agent.model = model
}

rule SetThinkingLevel {
    when: SetThinkingLevel(agent, level)
    ensures: agent.thinking_level = level
}

rule SetTools {
    when: SetTools(agent, tools)
    ensures: agent.tools = tools
}

rule ReplaceMessages {
    when: ReplaceMessages(agent, messages)
    ensures: agent.messages = messages
}

rule AppendMessage {
    when: AppendMessage(agent, message)
    ensures: agent.messages = agent.messages + {message}
}

rule Prompt {
    when: Prompt(agent, text, images)
    requires: agent.is_idle

    ensures: user_message = UserMessage{
        role: user,
        timestamp: now,
        content: BuildUserContent(text, images)
    }
    ensures: agent.messages = agent.messages + {user_message}
    ensures: agent.is_streaming = true
    ensures: AgentLoopStarted(agent)
}

rule Steer {
    when: Steer(agent, text)
    requires: agent.is_streaming

    ensures: agent.steering_queue = agent.steering_queue + {text}
}

rule FollowUp {
    when: FollowUp(agent, text)
    requires: agent.is_streaming

    ensures: agent.follow_up_queue = agent.follow_up_queue + {text}
}

rule AssistantDeltaReceived {
    when: AssistantDeltaReceived(agent, delta)
    requires: agent.is_streaming

    ensures: agent.stream_message = UpdateStreamingAssistant(agent.stream_message, delta)
}

rule ToolCallDiscovered {
    when: ToolCallDiscovered(agent, tool_call_id)
    requires: agent.is_streaming

    ensures: agent.pending_tool_calls = agent.pending_tool_calls + {tool_call_id}
}

rule ToolResultRecorded {
    when: ToolResultRecorded(agent, tool_call_id, result)

    ensures: agent.messages = agent.messages + {result}
    ensures: agent.pending_tool_calls = agent.pending_tool_calls - {tool_call_id}
}

rule AssistantTurnCompleted {
    when: AssistantTurnCompleted(agent, message)

    ensures: agent.messages = agent.messages + {message}
    ensures: agent.stream_message = null
    ensures: agent.is_streaming = false
}

rule Abort {
    when: Abort(agent)

    ensures: agent.is_streaming = false
    ensures: agent.error = "aborted"
    ensures: agent.stream_message = null
}

surface AgentApi {
    facing caller: AgentRuntime

    context agent: AgentState

    exposes:
        agent.is_idle
        agent.is_streaming
        agent.messages
        agent.stream_message
        agent.pending_tool_calls
        agent.error

    provides:
        CreateAgent(initial_state)
        ResetAgent(agent)
        SetSystemPrompt(agent, prompt)
        SetModel(agent, model)
        SetThinkingLevel(agent, level)
        SetTools(agent, tools)
        ReplaceMessages(agent, messages)
        AppendMessage(agent, message)
        Prompt(agent, text, images)
        Steer(agent, text)
        FollowUp(agent, text)
        Abort(agent)

    @guidance
        -- Agent supports mid-run steering and queued follow-up messages.
        -- Streaming state is represented by stream_message and is_streaming.
        -- Tool calls are tracked by pending_tool_calls until result messages arrive.
}

open question "Should steering preempt remaining tool calls or only affect next model turn?"
open question "Should follow-up queue preserve insertion order or support prioritization?"
