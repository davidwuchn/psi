-- allium: 2

-- ai-abstract-model.allium
-- Unified multi-provider AI model behavior.

value Provider {
    kind: anthropic | openai
}

value Api {
    kind: anthropic_messages | openai_completions | openai_codex_responses
}

value CacheControl {
    type: ephemeral
}

value SystemPromptBlock {
    kind: text
    text: String
    cache_control: CacheControl?
}

value CostBreakdown {
    input: Number
    output: Number
    cache_read: Number
    cache_write: Number
    total: Number
}

value Usage {
    input_tokens: Integer
    output_tokens: Integer
    cache_read_tokens: Integer
    cache_write_tokens: Integer
    total_tokens: Integer
    cost: CostBreakdown
}

value StreamOptions {
    temperature: Number?
    max_tokens: Integer?
    cache_retention: none | short | long
}

entity Conversation {
    id: String
    system_prompt: String?
    system_prompt_blocks: List<SystemPromptBlock>?
    status: active | completed | error
    created_at: Timestamp
    updated_at: Timestamp
}

entity Message {
    id: String
    conversation_id: String
    role: user | assistant | tool_result
    content: String
    timestamp: Timestamp

    provider: Provider?
    model_id: String?
    api: Api?
    usage: Usage?
    stop_reason: stop | length | tool_use | error | aborted
    error_message: String?
}

entity Tool {
    name: String
    description: String
    parameters: String
    cache_control: CacheControl?
}

entity Model {
    id: String
    name: String
    provider: Provider
    api: Api
    base_url: String

    supports_reasoning: Boolean
    supports_images: Boolean
    supports_text: Boolean

    context_window: Integer
    max_tokens: Integer

    input_cost: Number
    output_cost: Number
    cache_read_cost: Number
    cache_write_cost: Number
}

entity StreamSession {
    conversation_id: String
    model_id: String
    status: streaming | completed | failed
    started_at: Timestamp
    completed_at: Timestamp?

    temperature: Number?
    max_tokens: Integer?
    cache_retention: none | short | long
}

entity StreamEvent {
    id: String
    sequence: Integer
    event_type: start | text_start | text_delta | text_end | thinking_start | thinking_delta | thinking_end | toolcall_start | toolcall_delta | toolcall_end | done | error
    timestamp: Timestamp
    content_index: Integer?
    delta_text: String?
    error_message: String?
}

rule StartConversation {
    when: CreateConversation(system_prompt, system_prompt_blocks)

    ensures: conversation = Conversation{
        id: NewConversationId(),
        system_prompt: system_prompt,
        system_prompt_blocks: system_prompt_blocks,
        status: active,
        created_at: now,
        updated_at: now
    }
}

rule AddUserMessage {
    when: SendMessage(conversation, content)
    requires: conversation.status = active

    ensures: MessageCreated(
        conversation_id: conversation.id,
        role: user,
        content: content,
        timestamp: now
    )
    ensures: conversation.updated_at = now
}

rule StreamResponseStarted {
    when: RequestStream(conversation, model, options)
    requires: conversation.status = active
    requires: model.provider.kind in {anthropic, openai}

    ensures: session = StreamSession{
        conversation_id: conversation.id,
        model_id: model.id,
        status: streaming,
        started_at: now,
        completed_at: null,
        temperature: options.temperature,
        max_tokens: options.max_tokens,
        cache_retention: options.cache_retention
    }
}

rule CompleteStream {
    when: StreamCompleted(session)

    ensures: session.status = completed
    ensures: MessageCreated(
        conversation_id: session.conversation_id,
        role: assistant,
        content: BuildAssistantContent(session),
        timestamp: now
    )
    ensures: ConversationUpdatedAt(session.conversation_id, now)
}

rule HandleStreamError {
    when: StreamFailed(session, error_message)

    ensures: session.status = failed
    ensures: MessageCreated(
        conversation_id: session.conversation_id,
        role: assistant,
        content: "",
        timestamp: now,
        stop_reason: error,
        error_message: error_message
    )
}

rule ToolUseKeepsConversationActive {
    when: AssistantStopReasonRecorded(message, tool_use)

    ensures: ConversationStatus(message.conversation_id) = active
}

rule StopCompletesConversation {
    when: AssistantStopReasonRecorded(message, stop)

    ensures: ConversationStatus(message.conversation_id) = completed
}

surface ConversationAPI {
    facing client: APIClient

    provides:
        CreateConversation(system_prompt, system_prompt_blocks)
        SendMessage(conversation, content)
            when conversation.status = active
        RequestStream(conversation, model, options)
            when conversation.status = active
        AddTool(conversation, tool)
            when conversation.status = active

    exposes:
        Conversation
        Message
        StreamSession
}
