-- allium: 2

-- session-management.allium
-- AgentSession orchestration: lifecycle, prompting, model/thinking, and persistence hooks.

use "./agent.allium" as agent
use "./extension-system.allium" as ext
use "./compaction.allium" as compact
use "./session-core.allium" as core

external entity Model {
    provider: String
    id: String
    reasoning: Boolean
}

external entity AuthCredentials {
    provider: String
}

value TokenUsage {
    input: Integer
    output: Integer
    cache_read: Integer
    cache_write: Integer
    total: Integer
}

value SessionStats {
    id: String
    session_file: String?
    user_messages: Integer
    assistant_messages: Integer
    tool_calls: Integer
    total_messages: Integer
    tokens: TokenUsage
    cost: Decimal
}

value ContextUsage {
    tokens: Integer?
    context_window: Integer
    percent: Decimal?
}

entity SessionHostRuntime {
    host_id: String
    active_session_id: String?
    sessions: Set<AgentSession>
}

value SessionHostSnapshot {
    active_session_id: String?
    sessions: List<SessionSlot>
}

value SessionSlot {
    id: String
    name: String?
    is_streaming: Boolean
    is_active: Boolean
    parent_session_id: String?
}

entity SessionEntry {
    id: String
    parent_id: String?
    timestamp: Timestamp
    kind: message | thinking_level | model | compaction | branch_summary | custom | custom_message | label | session_info
    payload: Map<String, Any>
}

entity AgentSession {
    id: String
    session_file: String?
    name: String?
    worktree_path: String?

    model: Model?
    thinking_level: off | minimal | low | medium | high | xhigh
    is_streaming: Boolean
    is_compacting: Boolean

    interrupt_pending: Boolean
    interrupt_requested_at: Timestamp?

    steering_messages: Set<String>
    follow_up_messages: Set<String>

    auto_compaction_enabled: Boolean
    auto_retry_enabled: Boolean
    retry_attempt: Integer

    active_tools: Set<String>
    system_prompt: String

    journal: Set<SessionEntry>
    leaf_entry_id: String?
    journal_flushed: Boolean

    is_idle: not is_streaming and not is_compacting
    pending_message_count: steering_messages.count + follow_up_messages.count
    has_pending_messages: pending_message_count > 0
}

config {
    auto_retry_enabled: Boolean = true
    auto_retry_max_retries: Integer = 3
    auto_retry_base_delay_seconds: Integer = 2
    auto_retry_max_delay_seconds: Integer = 60
    default_active_tools: Set<String> = {"read", "bash", "edit", "write"}
}

rule NewSessionStarted {
    when: NewSessionStarted(session, input)

    ensures: core/SessionCreateRequested(
        project_id: input.project_id,
        worktree_path: session.worktree_path ?? input.worktree_path,
        system_prompt: session.system_prompt,
        name: session.name
    )

    ensures: session.is_streaming = false
    ensures: session.is_compacting = false
    ensures: session.interrupt_pending = false
    ensures: session.interrupt_requested_at = null
    ensures: session.steering_messages = {}
    ensures: session.follow_up_messages = {}
    ensures: session.retry_attempt = 0
    ensures: session.auto_retry_enabled = config.auto_retry_enabled
    ensures: session.active_tools = config.default_active_tools
}

rule UserPrompts {
    when: UserPrompts(session, text, images)

    requires: session.is_idle
    requires: session.model != null

    ensures: expanded = SkillAndTemplateExpanded(session, text)
    ensures: agent/Prompt(session.agent, expanded, images)
    ensures: SessionEntry.created(
        id: NewEntryId(),
        parent_id: session.leaf_entry_id,
        timestamp: now,
        kind: message,
        payload: {role: "user", text: expanded}
    )
}

rule PromptRoutingDefaultsToActiveSession {
    when: PromptRequested(host, text, images, session_id)
    requires: session_id = null
    requires: host.active_session_id != null

    ensures: UserPrompts(SessionById(host, host.active_session_id), text, images)
}

rule PromptRoutingUsesExplicitSession {
    when: PromptRequested(host, text, images, session_id)
    requires: session_id != null
    requires: SessionById(host, session_id) != null

    ensures: UserPrompts(SessionById(host, session_id), text, images)
}

rule UserPromptsWhileStreaming {
    when: UserPromptsWhileStreaming(session, text, behavior)

    requires: session.is_streaming
    requires: behavior in {steer, follow_up}

    ensures:
        if behavior = steer:
            session.steering_messages = session.steering_messages + {text}
            agent/Steer(session.agent, text)
        else:
            session.follow_up_messages = session.follow_up_messages + {text}
            agent/FollowUp(session.agent, text)
}

rule PromptWhileStreamingQueueModePersistsFollowUp {
    when: PromptWhileStreamingRequested(session, text, behavior)
    requires: session.is_streaming
    requires: behavior = queue

    ensures: UserPromptsWhileStreaming(session, text, behavior: follow_up)
}

rule PromptWhileStreamingSteerModePersistsSteering {
    when: PromptWhileStreamingRequested(session, text, behavior)
    requires: session.is_streaming
    requires: behavior = steer

    ensures:
        if session.interrupt_pending:
            UserPromptsWhileStreaming(session, text, behavior: follow_up)
        else:
            UserPromptsWhileStreaming(session, text, behavior: steer)
}

rule ExtensionCommandExecuted {
    when: UserPrompts(session, text, images)

    requires: StartsWith(text, "/")
    requires: ext/RegisteredCommandByName(CommandName(text)) != null

    ensures: ext/ExtensionCommandHandlerCalled(command_name: CommandName(text), command_args: CommandTail(text))
}

rule SessionStreamCompletedClearsQueues {
    when: AgentTurnCompleted(session)

    ensures: session.steering_messages = {}
    ensures: session.follow_up_messages = {}
}

rule SessionModelSelected {
    when: SessionModelSelected(session, model)

    ensures: session.model = model
    ensures: SessionEntry.created(
        id: NewEntryId(),
        parent_id: session.leaf_entry_id,
        timestamp: now,
        kind: model,
        payload: {provider: model.provider, model_id: model.id}
    )
}

rule SessionThinkingLevelSelected {
    when: SessionThinkingLevelSelected(session, level)

    ensures: session.thinking_level = level
    ensures: SessionEntry.created(
        id: NewEntryId(),
        parent_id: session.leaf_entry_id,
        timestamp: now,
        kind: thinking_level,
        payload: {thinking_level: level}
    )
}

rule SessionForked {
    when: SessionForked(session, entry_id)

    ensures: core/SessionForkRequested(
        parent_session_id: session.id,
        worktree_path: worktree_path_for(session.id),
        system_prompt: session.system_prompt,
        name: session.name
    )
    ensures: session.leaf_entry_id = entry_id
    ensures: session.retry_attempt = 0
}

rule NewRootSessionUsesGlobalBaseline {
    when: NewSessionStarted(session, input)
    requires: input.spawn_mode = new_root

    ensures: session.active_tools = config.default_active_tools
    ensures: session.system_prompt = GlobalBaselineSystemPrompt()
    ensures: session.extensions = GlobalBaselineExtensions()
}

rule SpawnedSessionInheritsThenDiverges {
    when: SessionSpawnedFromParent(child, parent, spawn_mode)
    requires: spawn_mode in {fork_head, fork_at_entry, subagent}

    ensures: child.active_tools = parent.active_tools
    ensures: child.system_prompt = parent.system_prompt
    ensures: child.extensions = parent.extensions
    ensures: child.model = parent.model

    ensures: ParentAndChildConfigsCanDivergeAfterSpawn(parent.id, child.id)
}

rule SessionResumed {
    when: SessionResumed(session, session_path)

    ensures: session.session_file = session_path
    ensures: session.is_streaming = false
    ensures: session.is_compacting = false
}

rule SessionEntryAppended {
    when: SessionEntryAppended(session, entry)

    ensures: core/SessionMessageAppendRequested(
        session: session.id,
        role: entry.payload.role,
        content: entry.payload.text,
        metadata: entry.payload,
        tool_name: entry.payload.tool_name,
        tool_call_id: entry.payload.tool_call_id
    )
    ensures: session.journal = session.journal + {entry}
    ensures: session.leaf_entry_id = entry.id
}

rule SessionStatsComputed {
    when: SessionStatsRequested(session)

    ensures: SessionStatsFor(session).id = session.id
    ensures: SessionStatsFor(session).session_file = session.session_file
    ensures: SessionStatsFor(session).total_messages = CountMessageEntries(session.journal)
}

rule SessionUsageTotalsAreSessionScoped {
    when: SessionStatsRequested(session)

    ensures: SessionTokenUsageTotals(session) aggregates only entries where entry.session = session.id
}

actor User {
    identified_by: id = "human-operator"
}

surface AgentSessionApi {
    facing caller: User

    context session: AgentSession

    exposes:
        session.id
        session.session_file
        session.name
        session.worktree_path
        session.model
        session.thinking_level
        session.is_streaming
        session.is_compacting
        session.pending_message_count
        session.active_tools

    provides:
        NewSessionStarted(session, input)
        SessionResumed(session, session_path)
        SessionForked(session, entry_id)
        UserPrompts(session, text, images)
        UserPromptsWhileStreaming(session, text, behavior)
        SessionModelSelected(session, model)
        SessionThinkingLevelSelected(session, level)
        SessionEntryAppended(session, entry)
        SessionStatsRequested(session)

    @guidance
        -- Session orchestrates agent turns, queue semantics, and lifecycle state.
        -- Slash commands may be intercepted before prompt dispatch.
        -- Persistence adapters append journal entries and restore session state.
        -- Core session identity and lineage are delegated to session-core.
        -- Session host routes prompt/mutation requests to explicit session id, else active session.
        -- Multiple sessions may stream concurrently; active-session switch is routing-only.
        -- `host/updated` is the single source of truth for the live session list in UIs.
        -- Emitted on subscribe (initial state) and whenever host session set or active_session_id changes.
        -- New session, fork, switch_session, and new_session all trigger HostUpdatedEmitted.
        -- Session slot name falls back to id prefix when name is null.
}

rule HostUpdatedEmittedOnSessionChange {
    when: SessionHostStateChanged(host)

    ensures: HostUpdatedEmitted(host, SessionHostSnapshot {
        active_session_id: host.active_session_id,
        sessions: MapToSlots(host.sessions, host.active_session_id)
    })
}

rule HostUpdatedEmittedOnSubscribe {
    when: RpcSubscribeCompleted(host)

    ensures: HostUpdatedEmitted(host, SessionHostSnapshot {
        active_session_id: host.active_session_id,
        sessions: MapToSlots(host.sessions, host.active_session_id)
    })
}

rule SessionSlotIsActiveWhenMatchesHost {
    when: SessionSlotProjected(host, slot)

    ensures: slot.is_active = (slot.id = host.active_session_id)
}

rule SessionSlotStreamingReflectsLivePhase {
    when: SessionSlotProjected(host, slot)
    requires: exists s in host.sessions where s.id = slot.id

    ensures: slot.is_streaming = SessionById(host, slot.id).is_streaming
}

open question "Should tree navigation branch-summary be synchronous or background async?"
open question "Should duplicate skill/template names be configurable (warn, error, or first-wins)?"