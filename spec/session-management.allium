-- allium: 2

-- session-management.allium
-- Session orchestration: prompting, model/thinking, prompt overlays, and persistence hooks.

use "./agent-extension.allium" as agent
use "./extension-system.allium" as ext
use "./compaction.allium" as compact
use "./session-core.allium" as core
use "./skills.allium" as skills
use "./prompt-templates.allium" as templates

external entity Model {
    provider: String
    id: String
    reasoning: Boolean
}

external entity AuthCredentials {
    provider: String
}

value TokenUsage {
    input: Integer
    output: Integer
    cache_read: Integer
    cache_write: Integer
    total: Integer
}

value SessionStats {
    id: String
    session_file: String?
    user_messages: Integer
    assistant_messages: Integer
    tool_calls: Integer
    total_messages: Integer
    tokens: TokenUsage
    cost: Decimal
}

value ContextUsage {
    tokens: Integer?
    context_window: Integer
    percent: Decimal?
}

entity SessionEntry {
    id: String
    parent_id: String?
    timestamp: Timestamp
    kind: message | thinking_level | model | compaction | branch_summary | custom | custom_message | label | session_info
    payload: Map<String, Any>
}

entity AgentSession {
    id: String
    context_id: String
    session_file: String?
    name: String?
    worktree_path: String?

    model: Model?
    thinking_level: off | minimal | low | medium | high | xhigh
    is_streaming: Boolean
    is_compacting: Boolean

    interrupt_pending: Boolean
    interrupt_requested_at: Timestamp?

    steering_messages: Set<String>
    follow_up_messages: Set<String>

    auto_compaction_enabled: Boolean
    auto_retry_enabled: Boolean
    retry_attempt: Integer

    active_tools: Set<String>
    effective_system_prompt: String
    prompt_overlays: Set<String>

    journal: Set<SessionEntry>
    leaf_entry_id: String?
    journal_flushed: Boolean

    is_idle: not is_streaming and not is_compacting
    pending_message_count: steering_messages.count + follow_up_messages.count
    has_pending_messages: pending_message_count > 0
}

config {
    auto_retry_enabled: Boolean = true
    auto_retry_max_retries: Integer = 3
    auto_retry_base_delay_seconds: Integer = 2
    auto_retry_max_delay_seconds: Integer = 60
}

rule NewSessionStarted {
    when: NewSessionStarted(session, input)

    ensures: core/SessionCreateRequested(
        project_id: input.project_id,
        worktree_path: session.worktree_path ?? input.worktree_path,
        system_prompt: session.effective_system_prompt,
        name: session.name
    )

    ensures: session.is_streaming = false
    ensures: session.is_compacting = false
    ensures: session.interrupt_pending = false
    ensures: session.interrupt_requested_at = null
    ensures: session.steering_messages = {}
    ensures: session.follow_up_messages = {}
    ensures: session.retry_attempt = 0
    ensures: session.auto_retry_enabled = config.auto_retry_enabled
}

rule SessionConfigDerivedFromContextOnCreate {
    when: core/SessionCreateRequested(project_id, worktree_path, system_prompt, name)
    requires: exists c in core/AgentContexts where c.project_id = project_id and c.worktree_path = worktree_path

    ensures: CreatedSession(project_id, worktree_path).active_tools = ContextTools(c.id)
    ensures: CreatedSession(project_id, worktree_path).effective_system_prompt = ComposeSessionPromptFromContext(
        context_id: c.id,
        requested_system_prompt: system_prompt,
        parent_session_id: null
    )
}

rule SpawnedSessionInheritsThenDiverges {
    when: SessionSpawnedFromParent(child, parent, spawn_mode)
    requires: spawn_mode in {fork_head, fork_at_entry, agent}

    ensures: child.active_tools = parent.active_tools
    ensures: child.effective_system_prompt = parent.effective_system_prompt
    ensures: child.model = parent.model

    ensures: ParentAndChildConfigsCanDivergeAfterSpawn(parent.id, child.id)
}

rule WorkflowChildSessionPromptRebuiltFromStructuredState {
    when: CreateChildSession(context_id, parent_session_id, relation, config)
    requires: relation in {agent, automation}
    requires: config.workflow_run_id != null

    ensures: child.prompt_mode = parent.prompt_mode unless config.prompt_mode_override != null
    ensures: child.effective_system_prompt = RecomposeSessionPrompt(context_id, child.id)

    @guidance
        -- Workflow-owned child sessions do not implicitly treat workflow-authored
        -- prompt text as full prompt replacement. Their provider-visible prompt is
        -- rebuilt from canonical session prompt state, then composed with any
        -- workflow-authored instruction layer and extension prompt contributions.
}

rule WorkflowChildSessionNilSelectionMeansFullPromptComposition {
    when: CreateChildSession(context_id, parent_session_id, relation, config)
    requires: relation in {agent, automation}
    requires: config.workflow_run_id != null
    requires: config.prompt_component_selection = null

    ensures: child.effective_system_prompt = RecomposeSessionPrompt(context_id, child.id)

    @guidance
        -- Nil prompt-component-selection means default/full prompt composition,
        -- not prompt rebuild bypass.
}

rule WorkflowChildSessionExplicitSelectionFiltersRecomposition {
    when: CreateChildSession(context_id, parent_session_id, relation, config)
    requires: relation in {agent, automation}
    requires: config.workflow_run_id != null
    requires: config.prompt_component_selection != null

    ensures: child.effective_system_prompt = RecomposeSessionPromptWithSelection(context_id, child.id, config.prompt_component_selection)

    @guidance
        -- Explicit selection narrows the recomposed prompt components while still
        -- using canonical prompt rebuilding.
}

rule WorkflowChildCapabilityNarrowingMatchesRenderedPromptVisibility {
    when: CreateChildSession(context_id, parent_session_id, relation, config)
    requires: relation in {agent, automation}
    requires: config.workflow_run_id != null

    ensures: RenderedTools(child.effective_system_prompt) = child.active_tools
    ensures: RenderedSkills(child.effective_system_prompt) = child.available_skills

    @guidance
        -- Workflow-declared tool/skill narrowing must stay coherent between child
        -- session state and rendered prompt sections.
}

rule UserPrompts {
    when: UserPrompts(session, text, images)

    requires: session.is_idle
    requires: session.model != null

    ensures: expanded = SkillAndTemplateExpanded(ContextFor(session.context_id), text)
    ensures: agent/Prompt(SessionAgent(session.id), expanded, images)
    ensures: SessionEntry.created(
        id: NewEntryId(),
        parent_id: session.leaf_entry_id,
        timestamp: now,
        kind: message,
        payload: {role: "user", text: expanded}
    )
}

rule PromptRoutingRequiresExplicitSessionId {
    when: PromptRequested(context, text, images, session_id)
    requires: session_id != null
    requires: SessionById(context, session_id) != null

    ensures: UserPrompts(SessionById(context, session_id), text, images)

    @guidance
        -- Core always requires an explicit session_id.
        -- Adapters (TUI, RPC, Emacs) maintain their own focus pointer and
        -- resolve it to a session_id before calling into core.
        -- There is no implicit "active session" fallback in the core.
}

rule PromptRoutingRejectsMissingSessionId {
    when: PromptRequested(context, text, images, session_id)
    requires: session_id = null

    ensures: OperationRejected(null, "session_id is required")

    @guidance
        -- A null session_id is an adapter error; the adapter must resolve
        -- its focus pointer to a concrete session_id before dispatching.
}

rule UserPromptsWhileStreaming {
    when: UserPromptsWhileStreaming(session, text, behavior)

    requires: session.is_streaming
    requires: behavior in {steer, follow_up}

    ensures:
        if behavior = steer:
            session.steering_messages = session.steering_messages + {text}
            agent/Steer(SessionAgent(session.id), text)
        else:
            session.follow_up_messages = session.follow_up_messages + {text}
            agent/FollowUp(SessionAgent(session.id), text)
}

rule PromptWhileStreamingQueueModePersistsFollowUp {
    when: PromptWhileStreamingRequested(session, text, behavior)
    requires: session.is_streaming
    requires: behavior = queue

    ensures: UserPromptsWhileStreaming(session, text, behavior: follow_up)
}

rule PromptWhileStreamingSteerModePersistsSteering {
    when: PromptWhileStreamingRequested(session, text, behavior)
    requires: session.is_streaming
    requires: behavior = steer

    ensures:
        if session.interrupt_pending:
            UserPromptsWhileStreaming(session, text, behavior: follow_up)
        else:
            UserPromptsWhileStreaming(session, text, behavior: steer)
}

rule ExtensionCommandExecuted {
    when: UserPrompts(session, text, images)

    requires: StartsWith(text, "/")
    requires: ext/RegisteredCommandByName(CommandName(text)) != null

    ensures: ext/ExtensionCommandHandlerCalled(command_name: CommandName(text), command_args: CommandTail(text))
}

rule SessionStreamCompletedClearsQueues {
    when: AgentTurnCompleted(session)

    ensures: session.steering_messages = {}
    ensures: session.follow_up_messages = {}
}

rule SessionModelSelected {
    when: SessionModelSelected(session, model)

    ensures: session.model = model
    ensures: SessionEntry.created(
        id: NewEntryId(),
        parent_id: session.leaf_entry_id,
        timestamp: now,
        kind: model,
        payload: {provider: model.provider, model_id: model.id}
    )
}

rule SessionThinkingLevelSelected {
    when: SessionThinkingLevelSelected(session, level)

    ensures: session.thinking_level = level
    ensures: SessionEntry.created(
        id: NewEntryId(),
        parent_id: session.leaf_entry_id,
        timestamp: now,
        kind: thinking_level,
        payload: {thinking_level: level}
    )
}

rule SessionPromptOverlayAdded {
    when: SessionPromptOverlayAdded(session, overlay_text)

    ensures: session.prompt_overlays = session.prompt_overlays + {overlay_text}
    ensures: session.effective_system_prompt = RecomposeSessionPrompt(session.context_id, session.id)
}

rule SessionPromptOverlayRemoved {
    when: SessionPromptOverlayRemoved(session, overlay_text)
    requires: overlay_text in session.prompt_overlays

    ensures: session.prompt_overlays = session.prompt_overlays - {overlay_text}
    ensures: session.effective_system_prompt = RecomposeSessionPrompt(session.context_id, session.id)
}

rule SessionForked {
    when: SessionForked(session, entry_id)

    ensures: core/SessionForkRequested(
        parent_session_id: session.id,
        worktree_path: worktree_path_for(session.id),
        system_prompt: session.effective_system_prompt,
        name: session.name
    )
    ensures: session.leaf_entry_id = entry_id
    ensures: session.retry_attempt = 0
}

rule SessionResumed {
    when: SessionResumed(session, session_path)

    ensures: session.session_file = session_path
    ensures: session.is_streaming = false
    ensures: session.is_compacting = false
}

rule SessionEntryAppended {
    when: SessionEntryAppended(session, entry)

    ensures: core/SessionMessageAppendRequested(
        session: session.id,
        role: entry.payload.role,
        content: entry.payload.text,
        metadata: entry.payload,
        tool_name: entry.payload.tool_name,
        tool_call_id: entry.payload.tool_call_id
    )
    ensures: session.journal = session.journal + {entry}
    ensures: session.leaf_entry_id = entry.id
}

rule SessionStatsComputed {
    when: SessionStatsRequested(session)

    ensures: SessionStatsFor(session).id = session.id
    ensures: SessionStatsFor(session).session_file = session.session_file
    ensures: SessionStatsFor(session).total_messages = CountMessageEntries(session.journal)
}

rule SessionUsageTotalsAreSessionScoped {
    when: SessionStatsRequested(session)

    ensures: SessionTokenUsageTotals(session) = AggregateEntriesForSession(session.id)
}

actor User {
    identified_by: id = "human-operator"
}

actor SessionConsumer {
    identified_by: "consumer-id"

    @guidance
        -- TUI, extensions, and RPC are session consumers.
        -- They interact with sessions exclusively via SessionId.
        -- They never hold or receive the process-scoped runtime context.
}

contract SessionService {
    query:   (session_id: core/SessionId, eql: Any) -> Any
    mutate:  (session_id: core/SessionId, op: String, params: core/JsonMap) -> Any
    prompt:  (session_id: core/SessionId, text: String) -> Void
    abort:   (session_id: core/SessionId) -> Void
    steer:   (session_id: core/SessionId, text: String) -> Void
}

rule ServiceRoutesToSessionBySessionId {
    when: ServiceOperationRequested(session_id, operation)
    requires: exists s in AgentSessions where s.id = session_id

    ensures: OperationExecutedAgainstSession(session_id, operation)

    @guidance
        -- The service surface resolves session_id to the session entry in
        -- canonical state. The consumer never sees the process-scoped ctx.
        -- session_id is always required; there is no active_session_id fallback
        -- in core. Adapters resolve their own focus pointer before calling in.
}

rule ServiceRejectsUnknownSessionId {
    when: ServiceOperationRequested(session_id, operation)
    requires: not exists s in AgentSessions where s.id = session_id

    ensures: OperationRejected(session_id, "session not found")
}

surface SessionServiceApi {
    facing consumer: SessionConsumer

    contracts:
        fulfils SessionService

    exposes:
        for s in AgentSessions:
            s.id
            s.name
            s.streaming_state
            s.status

    provides:
        ServiceOperationRequested(session_id, operation)

    @guarantee ConsumerNeverSeesCtx
        -- The process-scoped runtime context is an implementation detail.
        -- Consumers hold only a SessionId and the service reference.

    @guarantee SessionIdIsStableAcrossLifecycle
        -- A SessionId remains valid for the lifetime of the session in
        -- canonical state. Session switching is changing which SessionId
        -- the consumer addresses, not invalidating existing sessions.
}

surface AgentSessionApi {
    facing caller: User

    context session: AgentSession

    exposes:
        session.id
        session.context_id
        session.session_file
        session.name
        session.worktree_path
        session.model
        session.thinking_level
        session.is_streaming
        session.is_compacting
        session.interrupt_pending
        session.steering_messages
        session.follow_up_messages
        session.auto_compaction_enabled
        session.auto_retry_enabled
        session.retry_attempt
        session.active_tools
        session.effective_system_prompt
        session.prompt_overlays
        session.pending_message_count
        session.has_pending_messages

    provides:
        NewSessionStarted(session, input)
        UserPrompts(session, text, images)
        UserPromptsWhileStreaming(session, text, behavior)
        PromptWhileStreamingRequested(session, text, behavior)
        SessionModelSelected(session, model)
        SessionThinkingLevelSelected(session, level)
        SessionPromptOverlayAdded(session, overlay_text)
        SessionPromptOverlayRemoved(session, overlay_text)
        SessionForked(session, entry_id)
        SessionResumed(session, session_path)
        SessionEntryAppended(session, entry)
        SessionStatsRequested(session)

    @guarantee ContextOwnsSharedResources
        -- Skills, prompt templates, tools, and extensions are context resources.
        -- Session behavior may reference and compose them, but does not own them.

    @guarantee SessionOwnsConversationAndExecution
        -- A session owns its journal, prompt overlays, model selection, queues,
        -- and execution lifecycle.

    @guarantee EffectivePromptIsContextPlusSession
        -- effective_system_prompt is derived from context baseline/resources plus
        -- session-specific overlays and inheritance.
}
