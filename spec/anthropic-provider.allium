-- allium: 2

-- anthropic-provider.allium
--
-- Scope: Anthropic provider behavior for streaming completions in psi.
--
-- Source distillation:
--   - components/ai/src/psi/ai/providers/anthropic.clj
--   - components/ai/test/psi/ai/providers/anthropic_test.clj
--
-- Includes:
--   - Tool ID normalization to Anthropic's required pattern
--   - Message transformation (user, assistant, tool-result) to Anthropic API format
--   - Consecutive tool-result merging into single user message
--   - Request construction including auth, extended thinking, beta headers,
--     and prompt cache directives
--   - OAuth vs API-key auth dispatch
--   - Extended thinking level to budget_tokens mapping
--   - Temperature exclusion when extended thinking is active
--   - SSE streaming and event normalization to executor-facing event types
--   - Usage accumulation across message_start and message_delta events
--   - HTTP error handling and API error extraction
--
-- Excludes:
--   - Global conversation lifecycle semantics (see ai-abstract-model.allium)
--   - Model catalog contents and pricing values (data, not provider protocol)
--   - Session command/UI behavior and provider selection UX

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity AgentExecutor {}

value CacheControl {
    type: ephemeral
}

value TextBlock {
    kind: text
    text: String
    cache_control: CacheControl?
}

external entity Conversation {
    system_prompt: String?
    system_prompt_blocks: List<TextBlock>?
    messages: List<Map<String, Any>>
    tools: List<Map<String, Any>>
}

external entity Model {
    id: String
    base_url: String
    supports_reasoning: Boolean
    max_tokens: Integer?
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value StreamOptions {
    api_key: String?
    thinking_level: off | minimal | low | medium | high | xhigh | null
    temperature: Number?
    max_tokens: Integer?
}

value StreamUsage {
    input_tokens: Integer
    output_tokens: Integer
    cache_read_tokens: Integer
    cache_write_tokens: Integer
    total_tokens: Integer
    cost: Map<String, Any>?
}

value StreamEvent {
    event_type: start | text_start | text_delta | text_end | thinking_delta | toolcall_start | toolcall_delta | toolcall_end | done | error
    content_index: Integer?
    id: String?
    name: String?
    delta: String?
    reason: String?
    usage: StreamUsage?
    error_message: String?
    http_status: Integer?
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    default_api_url: String = "https://api.anthropic.com"
    messages_path: String = "/v1/messages"
    anthropic_version_header: String = "2023-06-01"
    default_temperature: Number = 0.7
    tool_id_pattern: String = "^[a-zA-Z0-9_-]+$"
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity AnthropicStream {
    conversation: Conversation
    model: Model
    options: StreamOptions

    resolved_api_key: String?
    oauth: Boolean = false
    usage_acc: StreamUsage
    block_types: Map<Integer, String>
    done: Boolean = false
}

------------------------------------------------------------
-- Prompt cache directives
------------------------------------------------------------

rule ConversationPromptUnitsMayCarryCacheControl {
    when: AnthropicStreamRequested(stream)

    ensures: ProviderMayInspect(stream.conversation.system_prompt_blocks)
    ensures: ProviderMayInspect(stream.conversation.tools)

    @guidance
        -- Cache directives are modeled on prompt units themselves, not as a
        -- provider-local index list. Anthropic-specific request shaping reads
        -- :cache_control from system prompt blocks and tool definitions.
}

rule SystemPromptBlocksPreferredOverFlatSystemPrompt {
    when: AnthropicStreamRequested(stream)
    requires: stream.conversation.system_prompt_blocks non-empty

    ensures: RequestBodyField("system") = ForEachBlock(stream.conversation.system_prompt_blocks,
        {type: "text", text: block.text, cache_control: block.cache_control when non-null})

    @guidance
        -- The provider prefers block form when available so cache directives can
        -- be attached to specific system prompt layers. Flat string form remains
        -- the fallback when no blocks are present.
}

rule FlatSystemPromptUsedWhenBlocksAbsent {
    when: AnthropicStreamRequested(stream)
    requires: stream.conversation.system_prompt_blocks = null or stream.conversation.system_prompt_blocks empty

    ensures:
        if stream.conversation.system_prompt != null:
            RequestBodyField("system") = stream.conversation.system_prompt
        else:
            RequestBodyOmits("system")
}

rule ToolDefinitionsPreserveCacheControl {
    when: ToolDefsBuilt(stream)
    requires: stream.conversation.tools non-empty

    ensures: ∀ tool. AnthropicToolDef({
        name: tool.name,
        description: tool.description,
        input_schema: tool.parameters,
        cache_control: tool.cache_control (when non-null)
    })
}

rule AnthropicCacheControlOnlyEmitsSupportedDirective {
    when: RequestBodyBuilt(stream)

    ensures: ∀ prompt_unit with cache_control. prompt_unit.cache_control.type = ephemeral

    @guidance
        -- The current provider only translates {:type :ephemeral}.
        -- Unsupported cache-control payloads are omitted rather than guessed.
}

------------------------------------------------------------
-- Tool ID Normalization
------------------------------------------------------------

rule ToolIdNormalizedBeforeRequest {
    when: ToolIdEncountered(raw_id)

    ensures:
        if Matches(raw_id, config.tool_id_pattern):
            NormalizedToolId(raw_id)
        else if Matches(Sanitize(raw_id), config.tool_id_pattern):
            NormalizedToolId(Sanitize(raw_id))
        else:
            NormalizedToolId(FallbackToolId())
}

rule ToolIdMappingIsConsistentWithinRequest {
    when: AnthropicStreamRequested(stream)

    ensures: ∀ raw_id. AllOccurrencesOfRawIdMapToSameNormalizedId(stream, raw_id)
}

------------------------------------------------------------
-- Message Transformation
------------------------------------------------------------

rule UserMessageTransformed {
    when: TransformingMessages(conversation)
    requires: message.role = :user

    ensures: AnthropicMessage({
        role: "user",
        content: [{type: "text", text: message.content.text ?? str(message.content)}]
    })
}

rule AssistantStructuredMessageTransformed {
    when: TransformingMessages(conversation)
    requires: message.role = :assistant
    requires: message.content.kind = :structured

    ensures: AnthropicMessage({
        role: "assistant",
        content: ForEachBlock(message.content.blocks,
            if block.kind = :text:
                {type: "text", text: block.text, cache_control: block.cache_control when non-null}
            if block.kind = :tool-call:
                {type: "tool_use", id: NormalizedToolId(block.id), name: block.name, input: block.input ?? {}, cache_control: block.cache_control when non-null}
            else:
                {type: "text", text: str(block)})
    })
}

rule AssistantTextMessageTransformed {
    when: TransformingMessages(conversation)
    requires: message.role = :assistant
    requires: message.content.kind != :structured

    ensures: AnthropicMessage({
        role: "assistant",
        content: [{type: "text", text: message.content.text ?? ""}]
    })
}

rule ToolResultMessageTransformed {
    when: TransformingMessages(conversation)
    requires: message.role = :tool-result

    let block = {
        type: "tool_result",
        tool_use_id: NormalizedToolId(message.tool_call_id),
        content: message.content.text ?? message.content,
        is_error: message.is_error (when true)
    }

    ensures:
        if PreviousOutputMessageIsToolResultUserMessage():
            MergeBlockIntoPreviousUserMessage(block)
        else:
            AnthropicMessage({role: "user", content: [block]})
}

rule ConsecutiveToolResultsMergedIntoSingleUserMessage {
    when: TransformingMessages(conversation)

    ensures: ∀ adjacent tool-result messages. ∃ single user message containing all their blocks
}

------------------------------------------------------------
-- Authentication
------------------------------------------------------------

rule ApiKeyResolved {
    when: AnthropicStreamRequested(stream)

    ensures: stream.resolved_api_key = stream.options.api_key ?? Environment("ANTHROPIC_API_KEY")
}

rule OAuthDetectedFromApiKey {
    when: AnthropicStreamRequested(stream)
    requires: Contains(stream.resolved_api_key, "sk-ant-oat")

    ensures: stream.oauth = true
}

------------------------------------------------------------
-- Extended Thinking
------------------------------------------------------------

rule ThinkingParamAbsentWhenModelLacksReasoning {
    when: ThinkingParamRequested(model, options)
    requires: model.supports_reasoning = false

    ensures: ThinkingParam(null)
}

rule ThinkingParamAbsentWhenLevelIsOff {
    when: ThinkingParamRequested(model, options)
    requires: model.supports_reasoning = true
    requires: options.thinking_level = off or options.thinking_level = null

    ensures: ThinkingParam(null)
}

rule ThinkingParamPresentForActiveLevel {
    when: ThinkingParamRequested(model, options)
    requires: model.supports_reasoning = true
    requires: options.thinking_level ∈ {minimal, low, medium, high, xhigh}

    ensures: ThinkingParam({type: "enabled", budget_tokens: BudgetForLevel(options.thinking_level)})
}

rule TemperatureExcludedWhenThinkingActive {
    when: RequestBodyBuilt(stream)
    requires: ThinkingParam(stream) != null

    ensures: RequestBodyDoesNotContain("temperature")
}

------------------------------------------------------------
-- Request Construction
------------------------------------------------------------

rule AnthropicRequestUrlBuilt {
    when: AnthropicStreamRequested(stream)

    ensures: RequestUrl(stream) = stream.model.base_url + config.messages_path
}

rule AnthropicRequestBodyBuilt {
    when: AnthropicStreamRequested(stream)

    ensures: RequestBodyContains("model", stream.model.id)
    ensures: RequestBodyContains("max_tokens", stream.options.max_tokens ?? stream.model.max_tokens)
    ensures: RequestBodyContains("messages", TransformedMessages(stream.conversation))
    ensures: RequestBodyContains("stream", true)
    ensures: RequestBodyContains("tools", ToolDefs(stream.conversation)) when stream.conversation.tools non-empty
    ensures: RequestBodyContains("thinking", ThinkingParam(stream)) when ThinkingParam(stream) != null
    ensures: RequestBodyContains("temperature", stream.options.temperature ?? config.default_temperature) when ThinkingParam(stream) = null
}

------------------------------------------------------------
-- SSE Parsing and usage
------------------------------------------------------------

rule MessageStartEmitsStartEvent {
    when: SseEventReceived(stream, "message_start", event_data)

    ensures: UsageAccUpdated(stream, {
        input_tokens: event_data.message.usage.input_tokens ?? 0,
        cache_read_tokens: event_data.message.usage.cache_read_input_tokens ?? 0,
        cache_write_tokens: event_data.message.usage.cache_creation_input_tokens ?? 0
    })
    ensures: Emit(StreamEvent{event_type: start})
}

rule MessageDeltaAccumulatesOutputUsage {
    when: SseEventReceived(stream, "message_delta", event_data)

    ensures: UsageAccUpdated(stream, {output_tokens: event_data.usage.output_tokens ?? 0})
}

rule FinalUsageTotalsCalculated {
    when: DoneEventReady(stream)

    let acc = stream.usage_acc
    ensures: FinalizedUsage(acc) = StreamUsage{
        input_tokens: acc.input_tokens,
        output_tokens: acc.output_tokens,
        cache_read_tokens: acc.cache_read_tokens,
        cache_write_tokens: acc.cache_write_tokens,
        total_tokens: acc.input_tokens + acc.output_tokens + acc.cache_read_tokens + acc.cache_write_tokens,
        cost: CalculateCost(stream.model, acc)
    }
}

surface AnthropicProviderApi {
    facing executor: AgentExecutor

    provides:
        AnthropicStreamRequested(stream)

    exposes:
        StreamEvent
        StreamUsage
}
