-- allium: 1

-- tools/runtime.allium
-- Built-in tools runtime: registration, dispatch, policy, temp-store, and stats.

use "./read.allium" as read
use "./bash.allium" as bash
use "./edit.allium" as edit
use "./write.allium" as write
use "./psi-tool.allium" as eql
use "./tool-naming.allium" as naming
use "../post-tool-processing.allium" as post_tool

value ToolSchema {
    name: String
    label: String
    description: String
    parameters: String
}

value ToolDefinition {
    name: String
    label: String
    description: String
    parameters: String
    execute: Function
}

value ToolOutputPolicy {
    max_lines: Integer
    max_bytes: Integer
}

value ToolOutputOverride {
    max_lines: Integer?
    max_bytes: Integer?
}

value ToolOutputTruncation {
    truncated: Boolean
    truncated_by: lines | bytes | none
    total_lines: Integer
    total_bytes: Integer
    output_lines: Integer
    output_bytes: Integer
    max_lines: Integer
    max_bytes: Integer
    first_line_exceeds_limit: Boolean
    last_line_partial: Boolean
}

value ToolCallOutputStat {
    tool_call_id: String
    tool_name: String
    timestamp: Timestamp
    limit_hit: Boolean
    truncated_by: lines | bytes | none
    effective_max_lines: Integer
    effective_max_bytes: Integer
    output_bytes: Integer
    context_bytes_added: Integer
}

value SessionToolOutputStats {
    total_context_bytes: Integer
    by_tool: Map<String, Integer>
    limit_hits_by_tool: Map<String, Integer>
}

value ProcessTempStore {
    root_dir: String
    created_at: Timestamp
    cleaned_at: Timestamp?
}

value ToolOperations {
    kind: local | remote | custom
    adapter_name: String?
}

config {
    built_in_dispatch_tools: Set<String> = {"read", "bash", "edit", "write"}
    tool_output_default_max_lines: Integer = 1000
    tool_output_default_max_bytes: Integer = 25600
    tool_output_overrides: Map<String, ToolOutputOverride> = {}
}

rule BuiltInToolSchemasExposed {
    when: ToolSchemasRequested()

    ensures: ContainsToolSchema("read")
    ensures: ContainsToolSchema("bash")
    ensures: ContainsToolSchema("edit")
    ensures: ContainsToolSchema("write")
    ensures: ContainsToolSchema("psi-tool")
}

rule RegisteredToolNamesMustBeCanonical {
    when: ToolSchemasRequested()

    ensures: AllToolSchemaNamesMatchPattern(naming/config.tool_name_pattern)
}

rule RuntimeToolDefinitionsExcludeFactoryOnlyTools {
    when: RuntimeToolsRequested()

    ensures: ContainsToolDefinition("read")
    ensures: ContainsToolDefinition("bash")
    ensures: ContainsToolDefinition("edit")
    ensures: ContainsToolDefinition("write")
    ensures: not ContainsToolDefinition("psi-tool")
}

rule ExecuteToolDispatchesBuiltIns {
    when: ExecuteToolCalled(tool_name, args)
    requires: tool_name in config.built_in_dispatch_tools

    ensures:
        if tool_name = "read":
            result = read/ExecuteRead(args)
        else if tool_name = "bash":
            result = bash/ExecuteBash(args)
        else if tool_name = "edit":
            result = edit/ExecuteEdit(args)
        else:
            result = write/ExecuteWrite(args)
}

rule ExecuteToolRejectsUnknownTool {
    when: ExecuteToolCalled(tool_name, args)
    requires: tool_name not in config.built_in_dispatch_tools

    ensures: Error.thrown("Unknown tool: " + tool_name)
}

rule EffectiveOutputPolicyResolved {
    when: EffectiveOutputPolicyRequested(tool_name)

    ensures:
        if HasOverride(tool_name):
            EffectiveOutputPolicy(tool_name).max_lines = OverrideMaxLinesOrDefault(tool_name)
            EffectiveOutputPolicy(tool_name).max_bytes = OverrideMaxBytesOrDefault(tool_name)
        else:
            EffectiveOutputPolicy(tool_name).max_lines = config.tool_output_default_max_lines
            EffectiveOutputPolicy(tool_name).max_bytes = config.tool_output_default_max_bytes
}

rule ProcessTempStoreCreatedOnStartup {
    when: PsiProcessStarted(process_id)

    ensures: ProcessTempStore.created(
        root_dir: CreateTempDir(prefix: "psi-tool-output-" + process_id),
        created_at: now,
        cleaned_at: null
    )
}

rule TruncatedArtifactsWrittenUnderProcessStore {
    when: TruncatedFullOutputPersistRequested(tool_call_id, tool_name, full_text)

    ensures: ReturnedFullOutputPath(tool_call_id) = TempFile.write(
        dir: ActiveProcessTempStore().root_dir,
        name: tool_name + "-" + tool_call_id + ".log",
        content: full_text
    )
}

rule ToolCallOutputStatRecorded {
    when: ToolResultFinalized(tool_call_id, tool_name, truncation, output_text, projected_context_text)

    ensures: ToolCallOutputStat.created(
        tool_call_id: tool_call_id,
        tool_name: tool_name,
        timestamp: now,
        limit_hit: truncation.truncated,
        truncated_by: truncation.truncated_by,
        effective_max_lines: EffectiveOutputPolicy(tool_name).max_lines,
        effective_max_bytes: EffectiveOutputPolicy(tool_name).max_bytes,
        output_bytes: Utf8Bytes(output_text),
        context_bytes_added: Utf8Bytes(projected_context_text)
    )
}

rule ToolResultsBecomeCanonicalStructuredEnvelopes {
    when: ToolResultFinalized(tool_call_id, tool_name, truncation, output_text, projected_context_text)

    ensures: CanonicalToolResultEnvelope.created(
        content: output_text,
        is_error: ToolCallErrorState(tool_call_id),
        details: ToolCallDetails(tool_call_id),
        meta: post_tool/ToolResultMeta{tool_name: tool_name, tool_call_id: tool_call_id},
        effects: ToolCallEffects(tool_call_id),
        enrichments: []
    )
    ensures: post_tool/CanonicalToolResultCreated(tool_call_id, tool_name)
}

rule FinalToolResultPassesThroughPostToolProcessing {
    when: ToolResultFinalized(tool_call_id, tool_name, truncation, output_text, projected_context_text)

    ensures: post_tool/PostToolProcessingRequested(post_tool/PostToolProcessorInput{
        session_id: ToolCallSessionId(tool_call_id),
        tool_name: tool_name,
        tool_call_id: tool_call_id,
        tool_args: ToolCallArgs(tool_call_id),
        tool_result: CanonicalResultFor(tool_call_id),
        worktree_path: ToolCallWorktreePath(tool_call_id)
    })
}

rule ToolOutputStatsAggregated {
    when: ToolOutputStatsRequested(session)

    ensures: SessionToolOutputStats(session).total_context_bytes = SumContextBytes(session)
    ensures: SessionToolOutputStats(session).by_tool = GroupContextBytesByTool(session)
    ensures: SessionToolOutputStats(session).limit_hits_by_tool = GroupLimitHitsByTool(session)
}

surface BuiltInToolsApi {
    facing caller: AgentSessionRuntime | ExtensionRuntime

    provides:
        ToolSchemasRequested()
        RuntimeToolsRequested()
        ExecuteToolCalled(tool_name, args)
        EffectiveOutputPolicyRequested(tool_name)

    exposes:
        ToolSchema
        ToolDefinition
        ToolCallOutputStat
        SessionToolOutputStats
        ProcessTempStore
        CanonicalToolResultEnvelope
}

open question "Should process temp-store cleanup also run opportunistically on startup for stale directories?"
