-- allium: 1

-- tools/bash.allium
-- Target behavior for the bash tool.

value BashArgs {
    command: String
    timeout: Integer?
}

value BashOutputOverride {
    max_lines: Integer?
    max_bytes: Integer?
}

value BashOptions {
    cwd: String?
    overrides: Map<String, BashOutputOverride>?
    command_prefix: String?
    on_update: Function?
    tool_call_id: String?
}

value BashTruncation {
    truncated: Boolean
    truncated_by: lines | bytes | none
    total_lines: Integer
    total_bytes: Integer
    output_lines: Integer
    output_bytes: Integer
    max_lines: Integer
    max_bytes: Integer
    last_line_partial: Boolean
}

value BashDetails {
    truncation: BashTruncation?
    full_output_path: String?
}

value BashResult {
    content: String
    is_error: Boolean
    details: BashDetails?
}

rule BashCommandPrefixApplied {
    when: ExecuteBash(args, opts)
    requires: opts.command_prefix != null

    ensures: resolved_command = opts.command_prefix + "\n" + args.command
}

rule BashCommandPrefixDefaultsToRawCommand {
    when: ExecuteBash(args, opts)
    requires: opts.command_prefix = null

    ensures: resolved_command = args.command
}

rule BashTimeoutDefaultsToThirtySeconds {
    when: ExecuteBash(args, opts)

    ensures: timeout_seconds = args.timeout or 30
}

rule BashUsesEffectivePolicyWithOverrides {
    when: ExecuteBash(args, opts)

    ensures: policy = EffectiveOutputPolicy(tool_name: "bash", overrides: opts.overrides or {})
}

rule BashExecutesWithShellDashC {
    when: ExecuteBash(args, opts)

    ensures: ProcessSpawnedWithShellDashC(ResolvedCommand(args, opts))
    ensures: ProcessUsesMergedStdoutStderr()
    ensures: ProcessUsesNullStdin()
}

rule BashRunsInCwdWhenProvided {
    when: ExecuteBash(args, opts)
    requires: opts.cwd != null

    ensures: ProcessWorkingDirectory() = opts.cwd
}

rule BashFinalResultUsesTailTruncation {
    when: BashProcessFinished(stdout, stderr, exit_code)

    let merged = stdout + stderr
    let truncation = TailTruncate(merged, EffectiveOutputPolicy("bash"))

    ensures:
        if IsBlank(truncation.content):
            result.content = "(no output)"
        else:
            result.content = truncation.content
    ensures: result.is_error = false
}

rule BashFinalResultIncludesTruncationDetailsWhenTruncated {
    when: BashProcessFinished(stdout, stderr, exit_code)

    let merged = stdout + stderr
    let truncation = TailTruncate(merged, EffectiveOutputPolicy("bash"))
    requires: truncation.truncated

    ensures: result.details.truncation = truncation
}

rule BashFinalResultIncludesFullOutputPathWhenTruncated {
    when: BashProcessFinished(stdout, stderr, exit_code)

    let merged = stdout + stderr
    let truncation = TailTruncate(merged, EffectiveOutputPolicy("bash"))
    requires: truncation.truncated

    ensures: path = PersistTruncatedFullOutput(
        tool_name: "bash",
        tool_call_id: opts.tool_call_id or RandomUuid(),
        full_text: merged
    )
    ensures: result.details.full_output_path = path
    ensures: Contains(result.content, "Full output")
    ensures: Contains(result.content, path)
}

rule BashFinalResultOmitsDetailsWhenNotTruncated {
    when: BashProcessFinished(stdout, stderr, exit_code)

    let merged = stdout + stderr
    let truncation = TailTruncate(merged, EffectiveOutputPolicy("bash"))
    requires: not truncation.truncated

    ensures: result.details = null
}

rule BashNonZeroExitMarksError {
    when: BashProcessFinished(stdout, stderr, exit_code)
    requires: exit_code != 0

    ensures: result.is_error = true
    ensures: Contains(result.content, "Command exited with code " + exit_code)
}

rule BashTimeoutMarksError {
    when: BashTimeoutReached(timeout_seconds)

    ensures: Process.killed()
    ensures: result.is_error = true
    ensures: result.details = null
    ensures: Contains(result.content, "Command timed out after " + timeout_seconds + " seconds")
}

rule BashOnUpdateReceivesFinalResultWhenProvided {
    when: BashResultReady(result)
    requires: opts.on_update != null

    ensures: OnUpdate(opts.on_update, result)
}

rule BashExecutionExceptionsReturnErrorPayload {
    when: ExecuteBash(args, opts)
    requires: ExceptionThrown(e)

    ensures: result = BashResult{
        content: "Command execution error: " + Message(e),
        is_error: true,
        details: null
    }
}

rule AbortBashReturnsTrueWhenProcessRunning {
    when: AbortBashCalled()
    requires: CurrentBashProcess() != null

    ensures: Process.killed(force: true)
    ensures: abort_result = true
}

rule AbortBashReturnsFalseWhenNoProcessRunning {
    when: AbortBashCalled()
    requires: CurrentBashProcess() = null

    ensures: abort_result = false
}

rule BashTempArtifactsStoredInProcessStore {
    when: PersistTruncatedFullOutput(tool_name: "bash", full_text)

    ensures: path in ActiveProcessTempStore().root_dir
}

surface BashToolApi {
    facing caller: AgentToolDispatcher

    provides:
        ExecuteBash(args, opts)
        AbortBashCalled()

    exposes:
        BashResult

    @guidance
        -- Truncated bash output must provide recoverable full_output_path metadata.
        -- on_update currently receives final-result snapshots (not chunk-stream deltas).
        -- Timeout errors currently return timeout text without partial captured output.
}
