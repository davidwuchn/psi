-- allium: 1

-- tools/app-query-tool.allium
-- Factory-only EQL query tool behavior.

value EqlQueryArgs {
    query: String
}

value EqlOutputOverride {
    max_lines: Integer?
    max_bytes: Integer?
}

value EqlQueryToolOptions {
    overrides: Map<String, EqlOutputOverride>?
    tool_call_id: String?
}

value EqlQueryTruncation {
    truncated: Boolean
    truncated_by: lines | bytes | none
    total_lines: Integer
    total_bytes: Integer
    output_lines: Integer
    output_bytes: Integer
    max_lines: Integer
    max_bytes: Integer
    first_line_exceeds_limit: Boolean
}

value EqlQueryDetails {
    truncation: EqlQueryTruncation?
    full_output_path: String?
}

value EqlQueryResult {
    content: String
    is_error: Boolean
    details: EqlQueryDetails?
}

value EqlQueryTool {
    name: String
    label: String
    description: String
    parameters: String
    execute: Function
}

rule EqlQueryToolCreatedFromBaseSchema {
    when: MakeEqlQueryToolCalled(query_fn, opts)

    ensures: tool.name = "app-query-tool"
    ensures: tool.label = "App Query Tool"
    ensures: tool.description = "Execute an EQL query against the live session graph. Returns session state, tool info, extension status, and more. Input is an EDN vector, e.g. [:psi.agent-session/phase :psi.agent-session/model]"
    ensures: tool.parameters = JsonSchemaStringForEqlQueryVector()
    ensures: ToolExecuteUsesQueryFn(tool, query_fn)
}

rule EqlQueryParsesEdnWithReadEvalDisabled {
    when: ExecuteEqlQuery(query_text)

    ensures: DynamicBinding(name: "*read-eval*", value: false)
    ensures: parsed = EdnReadString(query_text)
}

rule EqlQueryRequiresVector {
    when: ExecuteEqlQuery(query_text)
    requires: not IsVector(ParsedEdn(query_text))

    ensures: result = EqlQueryResult{
        content: "EQL query error: Query must be an EDN vector",
        is_error: true,
        details: null
    }
}

rule EqlQueryExecutesAndSerializes {
    when: ExecuteEqlQuery(query_text)
    requires: IsVector(ParsedEdn(query_text))

    ensures: q = ParsedEdn(query_text)
    ensures: raw = ExecuteBoundQueryFn(q)
    ensures: serialized = PrStr(raw)
}

rule EqlQueryUsesEffectivePolicyWithOverrides {
    when: ExecuteEqlQuery(query_text)
    requires: IsVector(ParsedEdn(query_text))

    ensures: policy = EffectiveOutputPolicy(tool_name: "app-query-tool", overrides: opts.overrides or {})
}

rule EqlQueryAppliesHeadTruncation {
    when: ExecuteEqlQuery(query_text)
    requires: IsVector(ParsedEdn(query_text))

    let serialized = PrStr(ExecuteBoundQueryFn(ParsedEdn(query_text)))
    let truncation = HeadTruncate(serialized, EffectiveOutputPolicy("app-query-tool"))

    ensures: result.is_error = false
    ensures:
        if truncation.truncated:
            result.details.truncation = truncation
        else:
            result.details = null
}

rule EqlQueryReturnsSerializedContentWhenNotTruncated {
    when: ExecuteEqlQuery(query_text)
    requires: IsVector(ParsedEdn(query_text))

    let serialized = PrStr(ExecuteBoundQueryFn(ParsedEdn(query_text)))
    let truncation = HeadTruncate(serialized, EffectiveOutputPolicy("app-query-tool"))
    requires: not truncation.truncated

    ensures: result.content = truncation.content
}

rule EqlQueryWritesFullOutputFileWhenTruncated {
    when: ExecuteEqlQuery(query_text)
    requires: IsVector(ParsedEdn(query_text))

    let serialized = PrStr(ExecuteBoundQueryFn(ParsedEdn(query_text)))
    let truncation = HeadTruncate(serialized, EffectiveOutputPolicy("app-query-tool"))
    requires: truncation.truncated

    ensures: path = PersistTruncatedFullOutput(
        tool_name: "app-query-tool",
        tool_call_id: opts.tool_call_id or RandomUuid(),
        full_text: serialized
    )
    ensures: result.details.full_output_path = path
}

rule EqlQueryTruncatedContentIncludesSummaryAndGuidance {
    when: ExecuteEqlQuery(query_text)
    requires: IsVector(ParsedEdn(query_text))

    let serialized = PrStr(ExecuteBoundQueryFn(ParsedEdn(query_text)))
    let truncation = HeadTruncate(serialized, EffectiveOutputPolicy("app-query-tool"))
    requires: truncation.truncated

    ensures: Contains(result.content, "Output truncated")
    ensures: Contains(result.content, "lines")
    ensures: Contains(result.content, "bytes")
    ensures: Contains(result.content, "Full output")
    ensures: Contains(result.content, "Use a narrower query")
    ensures: Contains(result.content, truncation.content)
}

rule EqlQueryTruncatedFilesUseProcessTempStore {
    when: PersistTruncatedFullOutput(tool_name: "app-query-tool", full_text)

    ensures: path in ActiveProcessTempStore().root_dir
}

rule EqlQueryConvertsExceptionsToErrorPayload {
    when: ExecuteEqlQuery(query_text)
    requires: ExceptionThrown(e)

    ensures: result = EqlQueryResult{
        content: "EQL query error: " + Message(e),
        is_error: true,
        details: null
    }
}

rule EqlQueryExcludedFromDirectDispatcher {
    when: ExecuteToolCalled("app-query-tool", args)

    ensures: Error.thrown("Unknown tool: app-query-tool")
}

surface EqlQueryToolApi {
    facing caller: AgentSessionRuntime

    provides:
        MakeEqlQueryToolCalled(query_fn)

    @guidance
        -- app-query-tool is factory-only because it requires live query context.
        -- Truncated outputs must include recoverable full_output_path metadata.
}
