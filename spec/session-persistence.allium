-- allium: 2

-- session-persistence.allium
-- Session journal disk I/O for append-only session files.

use "./session-management.allium" as session
use "./session-core.allium" as core

config {
    sessions_root: String = "~/.psi/agent/sessions"
    current_version: Integer = 3
}

value SessionHeader {
    type: String
    version: Integer
    id: String
    timestamp: Timestamp
    worktree_path: String
    parent_session: String?
}

value SessionInfo {
    path: String
    id: String
    worktree_path: String
    name: String?
    parent_session_path: String?
    created: Timestamp
    modified: Timestamp
    message_count: Integer
    first_message: String
    all_messages_text: String
}

entity SessionFile {
    path: String
    header: SessionHeader
    entries: Set<session/SessionEntry>
    version: Integer

    is_valid: header.type = "session" and header.id != ""
    worktree_path: header.worktree_path
}

entity SessionDirectory {
    path: String
}

rule SessionFileCreated {
    when: session/NewSessionStarted(s, input)
    requires: s.session_file = null

    ensures: dir = SessionDirectoryFor(s.worktree_path)
    ensures: s.session_file = NewSessionFilePath(dir.path, s.id, now)
    ensures: SessionFile.created(
        path: s.session_file,
        header: SessionHeader{
            type: "session",
            version: config.current_version,
            id: s.id,
            timestamp: now,
            worktree_path: s.worktree_path,
            parent_session: null
        },
        entries: {},
        version: config.current_version
    )
}

rule ForkedSessionFileCreated {
    when: session/SessionForked(s, entry_id)

    ensures: core/SessionContainment.created(
        parent_session_id: SessionId{value: s.id},
        child_session_id: SessionId{value: child_session_id_for_fork(s.id, entry_id)},
        relation: fork,
        created_at: now
    )

    let parent_path = s.session_file
    let branch_entries = EntriesOnPathTo(s.journal, entry_id)
    let dir = SessionDirectoryFor(s.worktree_path)

    ensures: s.session_file = NewSessionFilePath(dir.path, s.id, now)
    ensures: SessionFile.created(
        path: s.session_file,
        header: SessionHeader{
            type: "session",
            version: config.current_version,
            id: s.id,
            timestamp: now,
            worktree_path: s.worktree_path,
            parent_session: parent_path
        },
        entries: branch_entries,
        version: config.current_version
    )
    ensures: SessionFileWrittenToDisk(s.session_file)
}

rule EntryFlushedToDisk {
    when: session/SessionEntryAppended(s, entry)

    let has_assistant = JournalHasAssistantMessage(s.journal)

    ensures:
        if has_assistant and not s.journal_flushed:
            SessionFileWrittenToDisk(s.session_file, all_entries: s.journal)
            s.journal_flushed = true
        else if has_assistant:
            SessionFileAppendedToDisk(s.session_file, entry)
}

rule SessionLoaded {
    when: session/SessionResumed(s, session_path)

    let raw_entries = ParseSessionFile(session_path)
    requires: IsValidSessionHeader(raw_entries)

    let migrated = MigratedToCurrentVersion(raw_entries)
    ensures: s.id = HeaderSessionId(migrated)
    ensures: s.worktree_path = HeaderCwd(migrated)
    ensures: s.journal = SessionEntriesFromFile(migrated)
    ensures: s.journal_flushed = true
    ensures: s.leaf_entry_id = LastEntryId(s.journal)
}

rule MostRecentSessionFound {
    when: ContinueRecentRequested(worktree_path)

    let dir = SessionDirectoryFor(worktree_path)
    let files = ValidSessionFilesSortedByModifiedDesc(dir.path)

    ensures:
        if files.count > 0:
            result = files.first.path
        else:
            result = null
}

rule MigratedV1ToV2 {
    when: MigratedToCurrentVersion(raw_entries)
    requires: HeaderVersion(raw_entries) = 1

    ensures: AddEntryIdsAndParentLinks(raw_entries)
    ensures: SetHeaderVersion(raw_entries, 2)
}

rule MigratedV2ToV3 {
    when: MigratedToCurrentVersion(raw_entries)
    requires: HeaderVersion(raw_entries) = 2

    ensures: RenameMessageRole(raw_entries, from_role: "hookMessage", to_role: "custom")
    ensures: SetHeaderVersion(raw_entries, 3)
}

rule SessionDirectoryResolved {
    when: SessionDirectoryFor(worktree_path)

    ensures: encoded = EncodeCwdForSessionDir(worktree_path)
    ensures: result = SessionDirectory{path: config.sessions_root + "/" + encoded}
    ensures: DirectoryCreatedIfAbsent(result.path)
}

rule SessionsListed {
    when: SessionsListed(worktree_path, session_dir)

    let dir = session_dir ?? SessionDirectoryFor(worktree_path)
    ensures: result = BuildSessionInfoList(dir.path)
    ensures: result = SortSessionInfoByModifiedDesc(result)
}

rule AllSessionsListed {
    when: AllSessionsListed()

    ensures: result = BuildAllSessionInfo(config.sessions_root)
    ensures: result = SortSessionInfoByModifiedDesc(result)
}

surface SessionPersistenceApi {
    facing caller: session/AgentSession

    context s: session/AgentSession

    exposes:
        s.session_file
        s.journal_flushed

    provides:
        SessionFileCreated(s)
        EntryFlushedToDisk(s, entry)
        SessionLoaded(s, session_path)
        MostRecentSessionFound(s.worktree_path)
        SessionsListed(s.worktree_path, null)
        AllSessionsListed()

    @guidance
        -- Disk operations are mediated through this surface.
        -- Initial session file write is lazy until first assistant message.
        -- Fork writes immediately with branch history.
        -- parent_session in file header is the persisted lineage edge.
}

open question "Should the on-disk format stay NDJSON or move to EDN?"
open question "Should lazy flush remain first-assistant-message or flush every entry?"
open question "Do we need cross-process file locking for concurrent writers?"