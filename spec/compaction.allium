-- compaction.allium
--
-- Scope: Context compaction and branch summarisation for AgentSession.
--
-- Includes:
--   Compaction settings and preparation
--   Cut-point selection and split-turn handling
--   Manual compaction and auto-compaction (threshold + overflow recovery)
--   Extension interception points for compaction
--   Context-usage semantics immediately after compaction
--   Branch-abandon summarisation
--
-- Excludes:
--   AgentSession lifecycle outside compaction (session-management.allium)
--   Extension registration/runtime internals (extension-system.allium)
--   LLM provider transport/auth internals (agent.allium / ai-abstract-model.allium)

use "./agent.allium" as agent
use "./extension-system.allium" as ext

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity Model {
    provider: String
    id: String
    reasoning: Boolean
    contextWindow: Integer
}

external entity Agent {
    -- The core LLM agent (specified in agent.allium).
    state: agent/AgentState
    is_streaming: Boolean
}

external entity AgentSession {
    -- Session fields touched by compaction rules.
    model: Model?
    agent: Agent
    isCompacting: Boolean
    autoCompactionEnabled: Boolean
    is_idle: Boolean
    has_pending_messages: Boolean
}

external entity SessionEntry {
    id: String
    parentId: String?
    timestamp: Timestamp
}

external entity CompactionEntry {
    summary: String
    firstKeptEntryId: String
    tokensBefore: Integer
    details: String?
    fromHook: Boolean
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value CompactionSettings {
    enabled: Boolean
    reserveTokens: Integer
    keepRecentTokens: Integer
}

value FileOperationSummary {
    readFiles: List<String>
    modifiedFiles: List<String>
}

value CompactionPreparation {
    -- Prepared input for compaction + extension hooks.
    firstKeptEntryId: String
    messagesToSummarize: List<agent/AgentMessage>
    turnPrefixMessages: List<agent/AgentMessage>
    isSplitTurn: Boolean
    tokensBefore: Integer
    previousSummary: String?
    fileOps: FileOperationSummary
    settings: CompactionSettings
}

value CompactionResult {
    summary: String
    firstKeptEntryId: String
    tokensBefore: Integer
    details: String?        -- JSON metadata (often file-operation summary)
}

value BranchSummaryResult {
    summary: String?
    details: String?        -- JSON metadata (often file-operation summary)
    aborted: Boolean = false
    error: String?
}

value ContextUsage {
    tokens: Integer?            -- null after compaction until next successful assistant response
    contextWindow: Integer
    percent: Decimal?
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    auto_compaction_enabled_default: Boolean = true
    auto_compaction_reserve_tokens: Integer = 16384
    auto_compaction_keep_recent_tokens: Integer = 20000
    branch_summary_reserve_tokens: Integer = 16384
    -- Defaults come from settings; callers may override per-session.
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule SetAutoCompaction {
    when: SetAutoCompaction(session, enabled)
    ensures: session.autoCompactionEnabled = enabled
}

-- ── Preparation ─────────────────────────────────────────

rule CompactionPreparationComputed {
    -- Build CompactionPreparation from the active branch entries.
    when: CompactionPreparationRequested(session)

    let branchEntries = EntriesOnActivePath(session)

    -- If current leaf is already a compaction entry, no-op (already compacted).
    requires: LastEntry(branchEntries) is not CompactionEntry

    let boundaryStart = IndexAfterLatestCompaction(branchEntries)
    let cut = CutPointFound(branchEntries, boundaryStart, config.auto_compaction_keep_recent_tokens)

    ensures: preparation.firstKeptEntryId = EntryAt(branchEntries, cut.firstKeptEntryIndex).id
    ensures:
        if cut.isSplitTurn:
            preparation.messagesToSummarize = MessagesBetween(branchEntries, boundaryStart, cut.turnStartIndex)
            preparation.turnPrefixMessages = MessagesBetween(branchEntries, cut.turnStartIndex, cut.firstKeptEntryIndex)
        else:
            preparation.messagesToSummarize = MessagesBetween(branchEntries, boundaryStart, cut.firstKeptEntryIndex)
            preparation.turnPrefixMessages = []
    ensures: preparation.isSplitTurn = cut.isSplitTurn
    ensures: preparation.tokensBefore = EstimatedContextTokensSinceLatestCompaction(branchEntries)
    ensures: preparation.previousSummary = LatestCompactionSummary(branchEntries)
    ensures: preparation.fileOps = FileOperationsMergedFrom(
        LatestCompactionFileOps(branchEntries),
        preparation.messagesToSummarize,
        preparation.turnPrefixMessages
    )
    ensures: preparation.settings = EffectiveCompactionSettings(session)
}

rule CutPointSelection {
    -- Keep approximately keepRecentTokens from newest backward.
    -- Valid cut points: user/assistant/custom-message/branch-summary message boundaries.
    -- Invalid cut points: toolResult boundaries.
    when: CutPointRequested(branchEntries, boundaryStart, keepRecentTokens)

    ensures: cut = CutPointFound(branchEntries, boundaryStart, keepRecentTokens)
    ensures: EntryAt(branchEntries, cut.firstKeptEntryIndex) is not ToolResultBoundary
    ensures: cut.firstKeptEntryIndex = IncludesLeadingNonMessageEntries(branchEntries, cut.firstKeptEntryIndex, boundaryStart)
    ensures:
        if EntryAt(branchEntries, cut.firstKeptEntryIndex) starts_mid_turn:
            cut.isSplitTurn = true
            cut.turnStartIndex = NearestPriorTurnStart(branchEntries, cut.firstKeptEntryIndex, boundaryStart)
        else:
            cut.isSplitTurn = false
}

rule CompactionPreparationUnavailable {
    -- Manual/auto compaction rejects when there is no valid preparation.
    when: CompactionPreparationRequested(session)

    let branchEntries = EntriesOnActivePath(session)

    ensures:
        if branchEntries.count = 0:
            PreparationError(session) = nothing_to_compact
        else if LastEntry(branchEntries) is CompactionEntry:
            PreparationError(session) = already_compacted
}

rule CompactionSummaryGenerated {
    -- Default (LLM-based) compaction summary generation.
    when: CompactionSummaryGenerated(session, preparation, customInstructions?)

    ensures:
        if preparation.isSplitTurn and preparation.turnPrefixMessages.count > 0:
            result.summary = MergeSummaries(
                SummarizeHistory(
                    preparation.messagesToSummarize,
                    customInstructions,
                    preparation.previousSummary,
                    preparation.settings.reserveTokens
                ),
                SummarizeTurnPrefix(preparation.turnPrefixMessages, preparation.settings.reserveTokens)
            )
        else:
            result.summary = SummarizeHistory(
                preparation.messagesToSummarize,
                customInstructions,
                preparation.previousSummary,
                preparation.settings.reserveTokens
            )
    ensures: result.summary = result.summary + FormatFileOperations(preparation.fileOps)
    ensures: result.firstKeptEntryId = preparation.firstKeptEntryId
    ensures: result.tokensBefore = preparation.tokensBefore
    ensures: result.details = Json(preparation.fileOps)
}

-- ── Manual compaction ───────────────────────────────────

rule ManualCompaction {
    -- User triggers /compact. Agent is aborted first.
    when: ManualCompaction(session, customInstructions?)

    requires: exists session.model

    let preparation = CompactionPreparationRequested(session)
    requires: exists preparation
    requires: PreparationError(session) = null

    ensures: session.agent.abort()
    ensures: session.isCompacting = true
    ensures: ext/SessionBeforeCompactDispatched(session, preparation, EntriesOnActivePath(session), customInstructions)
    ensures:
        if SessionBeforeCompactCancelled(session):
            session.isCompacting = false
            result = null
        else:
            let result =
                if SessionBeforeCompactOverride(session) != null:
                    SessionBeforeCompactOverride(session)
                else:
                    CompactionSummaryGenerated(session, preparation, customInstructions)
            let fromExtension = SessionBeforeCompactOverride(session) != null
            let saved = CompactionEntry.created(
                summary: result.summary,
                firstKeptEntryId: result.firstKeptEntryId,
                tokensBefore: result.tokensBefore,
                details: result.details,
                fromHook: fromExtension
            )
            agent/ReplaceMessages(session.agent, RebuildFromEntries(session))
            session.isCompacting = false
            ext/SessionCompactDispatched(session, saved, fromExtension)
}

-- ── Auto-compaction: threshold ──────────────────────────

rule AutoCompactionTriggered {
    -- Fires after successful assistant turns when context exceeds window-reserve.
    when: _: agent/AgentEndEvent.emitted

    requires: session.autoCompactionEnabled
    requires: LastAssistantMessage(session).stopReason != error
    requires:
        ContextTokensFrom(LastAssistantMessage(session).usage)
        > session.model.contextWindow - config.auto_compaction_reserve_tokens

    ensures: AutoCompactionRun(session, reason: threshold, willRetry: false)
}

-- ── Auto-compaction: overflow ───────────────────────────

rule AutoCompactionOnOverflow {
    -- Fires when the LLM reports context overflow for the active model.
    when: _: agent/AgentEndEvent.emitted

    requires: session.autoCompactionEnabled
    requires: LastAssistantMessage(session).stopReason = error
    requires: IsContextOverflow(LastAssistantMessage(session), session.model.contextWindow)
    requires: MessageModelMatchesCurrentModel(LastAssistantMessage(session), session.model)
    requires: not MessagePredatesLatestCompaction(LastAssistantMessage(session), EntriesOnActivePath(session))

    ensures: agent/ReplaceMessages(session.agent, RemoveTrailingOverflowError(session.agent.state.messages))
    ensures: AutoCompactionRun(session, reason: overflow, willRetry: true)
}

rule AutoCompactionRun {
    -- Shared auto-compaction flow (threshold or overflow).
    when: AutoCompactionRun(session, reason, willRetry)

    ensures: ext/AutoCompactionStartDispatched(session, reason)
    ensures:
        let result = ManualCompaction(session, customInstructions: null)
        if AutoCompactionError(session) != null:
            ext/AutoCompactionEndDispatched(
                session,
                result: null,
                aborted: false,
                willRetry: false,
                errorMessage: AutoCompactionError(session)
            )
        else if result = null:
            ext/AutoCompactionEndDispatched(session, result: null, aborted: true, willRetry: false)
        else:
            ext/AutoCompactionEndDispatched(session, result: result, aborted: false, willRetry: willRetry)
            if willRetry:
                agent/Continue(session.agent)
            else if session.has_pending_messages or AgentHasQueuedMessages(session.agent):
                agent/Continue(session.agent)
}

-- ── Context usage semantics ─────────────────────────────

rule ContextUsageUnknownAfterCompaction {
    -- After compaction, context token count is unknown until a successful
    -- assistant response occurs after the latest compaction entry.
    when: ContextUsageRequested(session)

    requires: exists LatestCompactionEntry(EntriesOnActivePath(session))
    requires: not exists SuccessfulAssistantAfterLatestCompaction(EntriesOnActivePath(session))

    ensures: ContextUsageFor(session).tokens = null
    ensures: ContextUsageFor(session).contextWindow = session.model.contextWindow
    ensures: ContextUsageFor(session).percent = null
}

-- ── Branch summarisation ────────────────────────────────

rule BranchSummarised {
    -- Called when TreeNavigated with summarize=true.
    when: BranchSummarised(session, abandonedEntries, customInstructions?)

    requires: exists session.model

    let context = PrepareForBranchSummary(abandonedEntries, config.branch_summary_reserve_tokens)

    ensures: result = BranchSummaryExecuted(session, context, customInstructions)
    ensures:
        if result.summary != null:
            result.summary = BranchSummaryPreamble() + result.summary
}

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

actor User {
    identified_by: HumanOperator
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface CompactionApi {
    -- Compaction operations exposed to the session orchestrator.
    for caller: User

    context session: AgentSession

    exposes:
        session.isCompacting
        session.autoCompactionEnabled

    provides:
        ManualCompaction(caller, session, customInstructions?)
            when session.is_idle

        SetAutoCompaction(caller, session, enabled)

    guidance:
        -- ManualCompaction aborts any running agent turn before compacting.
        -- session_before_compact may cancel compaction or supply an explicit CompactionResult.
        -- Auto-compaction uses the same compaction pipeline, wrapped with start/end events.
        -- Threshold compaction does not auto-retry the failed turn (there was no failure).
        -- Overflow compaction retries the turn after successful compaction.
        -- After compaction, ContextUsage reports tokens = null until a post-compaction
        --   successful assistant response provides fresh usage.
}

------------------------------------------------------------
-- Deferred Specifications
------------------------------------------------------------

deferred CompactionPromptTemplates
    -- Exact summarization prompt text, update prompt text, and split-turn
    -- merge formatting are implementation details.

deferred TokenEstimator.heuristics
    -- Message token estimation details (usage reconciliation + fallback heuristics).

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open_question "Custom instructions mode: should compaction support replaceInstructions (replace base prompt) in addition to append-only customInstructions?"

open_question "Auto-compaction cancellation UX: when auto-compaction is cancelled, should the session emit a user-visible cancellation entry or remain silent?"
