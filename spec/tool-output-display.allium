-- allium: 1

-- tool-output-display.allium
-- Interactive-mode orchestration for displaying tool output.

use "./tool-output-rendering.allium" as render

value AssistantToolCall {
    tool_call_id: String
    tool_name: String
    arguments: String
}

value AssistantMessageFrame {
    tool_calls: Set<AssistantToolCall>
    stop_reason: streaming | completed | aborted | error
    error_message: String?
}

value ToolExecutionStartEvent {
    tool_call_id: String
    tool_name: String
    args: String
}

value ToolExecutionUpdateEvent {
    tool_call_id: String
    partial_output: render/ToolOutputPayload
}

value ToolExecutionEndEvent {
    tool_call_id: String
    output: render/ToolOutputPayload
    is_error: Boolean
}

entity ToolOutputBinding {
    tool_call_id: String
    tool_name: String
    args: String
    view: render/ToolOutputView
}

entity ToolOutputDisplayState {
    tools_expanded: Boolean
    show_images: Boolean

    active_tool_bindings: Set<ToolOutputBinding>
    rendered_tool_views: Set<render/ToolOutputView>
}

config {
    expand_tools_action: String = "expandTools"
}

rule AssistantFrameAddsToolRows {
    when: AssistantMessageUpdated(display, frame)

    ensures:
        for call in frame.tool_calls:
            if not exists ToolOutputBinding with tool_call_id = call.tool_call_id:
                view = render/ToolOutputView{
                    tool_call_id: call.tool_call_id,
                    tool_name: call.tool_name,
                    status: pending,
                    expanded: display.tools_expanded,
                    show_images: display.show_images,
                    args: call.arguments,
                    parsed_args: null,
                    output: null,
                    capabilities: null,
                    header: "",
                    visible_text: "",
                    warnings: {},
                    background: pending,
                    inline_images: {},
                    image_fallback_count: 0
                }
                binding = ToolOutputBinding{
                    tool_call_id: call.tool_call_id,
                    tool_name: call.tool_name,
                    args: call.arguments,
                    view: view
                }
                display.active_tool_bindings = display.active_tool_bindings + {binding}
                display.rendered_tool_views = display.rendered_tool_views + {view}
}

rule AssistantFrameUpdatesKnownToolArgs {
    when: AssistantMessageUpdated(display, frame)

    ensures:
        for call in frame.tool_calls:
            binding = ToolBindingById(display.active_tool_bindings, call.tool_call_id)
            if binding != null:
                binding.args = call.arguments
                binding.view.args = call.arguments
}

rule AssistantMessageEndWithFailureMarksPendingRowsError {
    when: AssistantMessageEnded(display, frame)
    requires: frame.stop_reason in {aborted, error}

    ensures:
        for binding in display.active_tool_bindings:
            binding.view.status = error
            binding.view.output = render/ToolOutputPayload{
                text: frame.error_message ?? "Error",
                images: {},
                is_error: true,
                details: null
            }
    ensures: display.active_tool_bindings = {}
}

rule ToolExecutionStartBackfillsMissingToolRow {
    when: ToolExecutionStarted(display, event)
    requires: ToolBindingById(display.active_tool_bindings, event.tool_call_id) = null

    ensures: view = render/ToolOutputView{
        tool_call_id: event.tool_call_id,
        tool_name: event.tool_name,
        status: running,
        expanded: display.tools_expanded,
        show_images: display.show_images,
        args: event.args,
        parsed_args: null,
        output: null,
        capabilities: null,
        header: "",
        visible_text: "",
        warnings: {},
        background: pending,
        inline_images: {},
        image_fallback_count: 0
    }
    ensures: binding = ToolOutputBinding{
        tool_call_id: event.tool_call_id,
        tool_name: event.tool_name,
        args: event.args,
        view: view
    }
    ensures: display.active_tool_bindings = display.active_tool_bindings + {binding}
    ensures: display.rendered_tool_views = display.rendered_tool_views + {view}
}

rule ToolExecutionStartPromotesPendingRowToRunning {
    when: ToolExecutionStarted(display, event)

    let binding = ToolBindingById(display.active_tool_bindings, event.tool_call_id)
    requires: binding != null

    ensures: binding.args = event.args
    ensures: binding.view.args = event.args
    ensures: binding.view.status = running
}

rule ToolExecutionUpdateStreamsPartialOutput {
    when: ToolExecutionUpdated(display, event)

    let binding = ToolBindingById(display.active_tool_bindings, event.tool_call_id)
    requires: binding != null

    ensures: binding.view.status = running
    ensures: binding.view.output = event.partial_output
}

rule ToolExecutionEndFinalizesRow {
    when: ToolExecutionEnded(display, event)

    let binding = ToolBindingById(display.active_tool_bindings, event.tool_call_id)
    requires: binding != null

    ensures:
        if event.is_error:
            binding.view.status = error
        else:
            binding.view.status = success

    ensures: binding.view.output = event.output
    ensures: binding.view.output.is_error = event.is_error
    ensures: display.active_tool_bindings = RemoveBinding(display.active_tool_bindings, binding)
}

rule SessionHistoryRenderResetsToolDisplayState {
    when: SessionHistoryRenderStarted(display)

    ensures: display.active_tool_bindings = {}
    ensures: display.rendered_tool_views = {}
}

rule ToggleToolExpansionViaKeybinding {
    when: KeybindingActionTriggered(display, action)
    requires: action = config.expand_tools_action

    ensures: SetToolsExpanded(display, not display.tools_expanded)
}

rule SetToolsExpandedAppliesToAllRenderedRows {
    when: SetToolsExpanded(display, expanded)

    ensures: display.tools_expanded = expanded
    ensures:
        for view in display.rendered_tool_views:
            view.expanded = expanded
    ensures: ChatExpandableComponentsSetExpanded(expanded)
}

rule ShowImagesSettingPropagatesToToolRows {
    when: SetShowImages(display, show_images)

    ensures: display.show_images = show_images
    ensures:
        for view in display.rendered_tool_views:
            view.show_images = show_images
}

actor User {
    identified_by: id = "human-operator"
}

actor ExtensionModule {
    identified_by: id = "extension-module"
}

surface ToolOutputDisplayApi {
    facing caller: User | ExtensionModule

    context display: ToolOutputDisplayState

    exposes:
        display.tools_expanded
        display.show_images
        display.rendered_tool_views

    provides:
        AssistantMessageUpdated(display, frame)
        AssistantMessageEnded(display, frame)
        ToolExecutionStarted(display, event)
        ToolExecutionUpdated(display, event)
        ToolExecutionEnded(display, event)
        SessionHistoryRenderStarted(display)
        KeybindingActionTriggered(display, action)
        SetToolsExpanded(display, expanded)
        SetShowImages(display, show_images)

    @guidance
        -- Shared lifecycle across UIs (TUI, Emacs, future frontends).
        -- Expansion state is global within a chat view.
        -- New rows inherit expansion and image-visibility state.
        -- Tool rows are correlated strictly by tool_call_id.
}

open question "Should expansion remain global, or move to per-tool-row expansion in long transcripts?"
open question "Should replay preserve partial stream snapshots, or only final tool results?"
