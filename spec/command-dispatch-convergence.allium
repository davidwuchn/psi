--   - Update extension mutation op whitelist

------------------------------------------------------------
-- Surface
------------------------------------------------------------

surface CommandDispatchConvergence {
    facing caller: AllCommandSurfaces

    provides:
        -- Every state-mutating command produces a dispatch event
        CommandDispatched(command_text, dispatch_event)
        -- Every dispatch event is traceable
        CommandTraced(dispatch_event, dispatch_id)

    @guidance
        -- commands.clj is the text parser + formatter layer only.
        -- *-in! functions are the canonical shared execution point.
        -- Mutations are Pathom wrappers around *-in! for extension access.
        -- Dispatch events are the single source of truth for state changes.
        -- Read-only commands stay as EQL queries (no dispatch needed).
        -- Adapter signals stay as typed return values (no dispatch needed).
}
