-- allium: 2

-- openai-provider.allium
--
-- Scope: OpenAI provider behavior for streaming completions in psi.
--
-- Source distillation:
--   - components/ai/src/psi/ai/providers/openai.clj
--   - components/ai/test/psi/ai/providers/openai_test.clj
--
-- Includes:
--   - API dispatch between OpenAI chat completions and Codex responses
--   - Request construction, auth requirements, and URL resolution
--   - Streaming event normalization to executor-facing event types
--   - Tool-call terminal assembly behavior (buffer by index, validate at boundary, visible errors)
--   - Reasoning/thinking mapping and usage normalization
--   - Provider request/response capture callbacks with header redaction
--
-- Excludes:
--   - Global conversation lifecycle semantics (see ai-abstract-model.allium)
--   - Session command/UI behavior and provider selection UX
--   - Model catalog contents and pricing values (data, not provider protocol)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity AgentExecutor {}

external entity Conversation {
    system_prompt: String?
    messages: List<Map<String, Any>>
    tools: List<Map<String, Any>>
}

external entity Model {
    id: String
    provider: String
    api: String
    base_url: String?
    supports_reasoning: Boolean
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value ProviderCallbackHandle {
    id: String
}

value StreamOptions {
    api_key: String?
    thinking_level: off | minimal | low | medium | high | xhigh
    temperature: Number?
    max_tokens: Integer?
    id: String?

    on_provider_request: ProviderCallbackHandle?
    on_provider_response: ProviderCallbackHandle?
}

value StreamUsage {
    input_tokens: Integer
    output_tokens: Integer
    cache_read_tokens: Integer
    cache_write_tokens: Integer
    total_tokens: Integer
    cost: Number?
}

value StreamEvent {
    event_type: start | text_delta | thinking_delta | toolcall_start | done | error
    content_index: Integer?
    id: String?
    name: String?
    delta_text: String?
    reason: String?
    usage: StreamUsage?
    error_message: String?
    http_status: Integer?
}

value ProviderRequest {
    url: String
    headers: Map<String, String>
    body: String
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    default_completions_base_url: String = "https://api.openai.com/v1"
    default_codex_base_url: String = "https://chatgpt.com/backend-api"

    codex_beta_header: String = "responses=experimental"
    completions_temperature_default: Number = 0
    default_reasoning_effort: String = "medium"

    sse_data_prefix: String = "data: "
    sse_done_sentinel: String = "[DONE]"
    codex_completed_event_types: Set<String> = {"response.completed", "response.done"}
    codex_failed_event_types: Set<String> = {"response.failed", "error"}

    -- thinking_level_to_effort: off->null, minimal->"minimal", low->"low",
    --   medium->"medium", high->"high", xhigh->"high"
    -- (Map<String,String?> literal syntax not supported by parser; expressed as guidance)

    completions_reasoning_part_types: Set<String> = {
        "reasoning", "reasoning_text", "reasoning_content",
        "reasoning_summary", "summary", "summary_text"
    }

    codex_reasoning_event_types: Set<String> = {
        "response.reasoning_summary_text.delta",
        "response.reasoning_text.delta",
        "response.reasoning_summary.delta",
        "response.reasoning.delta"
    }
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity OpenAIStream {
    conversation: Conversation
    model: Model
    options: StreamOptions

    request_api: openai_completions | openai_codex_responses
    request_url: String?

    started: Boolean = false
    done: Boolean = false

    resolved_api_key: String?
    chatgpt_account_id: String?

    -- Buffered raw tool-call fragments keyed by provider index (or arrival order fallback).
    buffered_tool_calls: Map<Integer, String>
}

------------------------------------------------------------
-- Routing and Request Construction
------------------------------------------------------------

rule OpenAIProviderDispatchesByModelApi {
    when: OpenAIStreamRequested(stream)
    requires: stream.model.provider = "openai"

    ensures:
        if stream.model.api = "openai-codex-responses":
            stream.request_api = openai_codex_responses
        else:
            stream.request_api = openai_completions
}

rule OpenAIApiKeyResolved {
    when: OpenAIStreamRequested(stream)

    ensures: stream.resolved_api_key = stream.options.api_key ?? Environment("OPENAI_API_KEY")
}

rule CompletionsUrlResolved {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_completions

    let base = stream.model.base_url ?? config.default_completions_base_url
    ensures: stream.request_url = TrimTrailingSlash(base) + "/chat/completions"
}

rule CodexUrlResolved {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_codex_responses

    let base = TrimTrailingSlash(stream.model.base_url ?? config.default_codex_base_url)
    ensures:
        if EndsWith(base, "/codex/responses"):
            stream.request_url = base
        else if EndsWith(base, "/codex"):
            stream.request_url = base + "/responses"
        else:
            stream.request_url = base + "/codex/responses"
}

rule CodexRequestRequiresApiKey {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_codex_responses
    requires: IsBlank(stream.resolved_api_key)

    ensures: ApiKeyUnavailable("openai")
    ensures: Emit(StreamEvent{event_type: error, error_message: "OpenAI API key is required"})
}

rule CodexExtractsChatGptAccountId {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_codex_responses
    requires: not IsBlank(stream.resolved_api_key)

    ensures: stream.chatgpt_account_id = JwtClaim(stream.resolved_api_key, "https://api.openai.com/auth", "chatgpt_account_id")
}

rule CodexRequiresChatGptAccountId {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_codex_responses
    requires: not IsBlank(stream.resolved_api_key)
    requires: IsBlank(stream.chatgpt_account_id)

    ensures: Emit(StreamEvent{event_type: error, error_message: "OpenAI Codex requires ChatGPT OAuth access token (missing chatgpt_account_id)"})
}

rule ReasoningEffortMappedFromThinkingLevel {
    when: ReasoningEffortRequested(model, options)

    ensures:
        if not model.supports_reasoning:
            ReasoningEffortResult(null)
        else:
            ReasoningEffortResult(MapGetOrDefault(config.thinking_level_to_effort, options.thinking_level, config.default_reasoning_effort))
}

------------------------------------------------------------
-- Thinking/Reasoning Delta Reconstruction
------------------------------------------------------------

rule CompletionsReasoningDeltaExtractedFromChunk {
    when: CompletionsChunkReceived(stream, chunk)
    requires: stream.request_api = openai_completions

    -- delta = first choice delta from chunk
    -- Fan-in priority order (first match wins):
    --   1. delta.reasoning.content  (nested map, :content key)
    --   2. delta.reasoning.summary  (nested map, :summary key)
    --   3. delta.reasoning_content  (flat key)
    --   4. delta.reasoning as bare String
    --   5. delta.reasoning as Map   -> .content / .summary / .text / .delta
    --   6. delta.reasoning as List<Map> where part type ∈ reasoning_part_types
    --      -> part.text / part.content / part.delta / part.reasoning / part.summary
    --   7. delta.content as List<Map> where part type ∈ reasoning_part_types
    --      -> part.text / part.content / part.delta / part.summary

    ensures:
        if ExtractReasoningDelta(delta) != null:
            Emit(StreamEvent{
                event_type: thinking_delta,
                content_index: 0,
                delta_text: ExtractReasoningDelta(delta)
            })

    @guidance
        -- String fragments inside nested maps/vectors are normalized by a recursive
        -- helper (string-fragment) that resolves .text / .content / .delta / .summary /
        -- .value leaves. Non-string scalars (numbers, keywords) are coerced to string.
        -- Sequential fragments are joined without separator.
        -- nil is returned when no textual content is found at any probe site.
}

rule CodexReasoningDeltaExtractedFromEvent {
    when: CodexEventReceived(stream, event)
    requires: stream.request_api = openai_codex_responses

    -- Four Codex SSE event types carry reasoning text:
    --   "response.reasoning_summary_text.delta"
    --   "response.reasoning_text.delta"
    --   "response.reasoning_summary.delta"
    --   "response.reasoning.delta"
    -- All four are normalized to the same thinking_delta shape.

    ensures:
        if EventType(event) in {
            "response.reasoning_summary_text.delta",
            "response.reasoning_text.delta",
            "response.reasoning_summary.delta",
            "response.reasoning.delta"
        } and StringFragment(event.delta) != null:
            Emit(StreamEvent{
                event_type: thinking_delta,
                content_index: 0,
                delta_text: StringFragment(event.delta)
            })
}

rule ThinkingDeltaEmittedOnlyWhenNonEmpty {
    when: ThinkingDeltaReady(stream, text)
    requires: IsBlank(text)

    ensures: ThinkingDeltaSuppressed(stream)
}

-- Thinking deltas bypass the turn statechart entirely.
-- They are forwarded directly to the progress queue so they can reach
-- the UI layer without waiting for text/tool accumulation to complete.
rule ThinkingDeltaBypassesTurnStatechart {
    when: ThinkingDeltaEmitted(stream, event)

    ensures: ProgressQueueReceives(ThinkingDeltaProgressEvent{
        event_kind: thinking_delta,
        text: CoerceToString(event.delta_text)
    })
    ensures: TurnStatechartNotNotified(stream, event)

    @guidance
        -- text-delta events feed into the turn statechart (turn/text-delta).
        -- thinking-delta events skip the statechart and go straight to
        -- emit-progress! so they appear in the UI mid-stream independently
        -- of text accumulation state.
        -- delta_text is always coerced to String (str) before enqueue.
}

-- RPC wire translation for thinking deltas.
rule ThinkingDeltaTranslatedToWireEvent {
    when: ProgressQueueDrained(thinking_delta_event)

    ensures: WireEventEmitted("assistant/thinking-delta", {text: thinking_delta_event.text})

    @guidance
        -- "assistant/thinking-delta" is a first-class wire event topic with
        -- required payload key #{:text}. It is validated by the RPC layer
        -- alongside all other progress event types.
}

------------------------------------------------------------
-- UI Accumulation and Lifecycle
------------------------------------------------------------

-- TUI accumulates thinking deltas into a single string state slot.
-- The slot is initialized to nil at turn start and rendered inline above
-- the assistant text block as a dim "ψ⋯ <text>" line.
rule TuiThinkingDeltaAccumulated {
    when: WireEventReceived(tui, "assistant/thinking-delta", payload)

    ensures: tui.stream_thinking = Concat(tui.stream_thinking ?? "", payload.text)
    ensures: ViewRendered(tui, render_stream_thinking(tui.stream_thinking))

    @guidance
        -- render_stream_thinking wraps non-blank text as dim-styled "ψ⋯ <text>\n".
        -- Blank/nil thinking is suppressed entirely from view.
        -- stream_thinking is reset to nil on turn start, tool-start, and turn end.
}

-- Emacs accumulates thinking deltas with pure concat (not snapshot-merge).
-- The live thinking block is a single buffer region, upserted on every delta.
rule EmacsThinkingDeltaAccumulated {
    when: WireEventReceived(emacs, "assistant/thinking-delta", payload)

    ensures: emacs.thinking_in_progress = Concat(emacs.thinking_in_progress ?? "", payload.text)
    ensures: ThinkingLineUpserted(emacs, emacs.thinking_in_progress)

    @guidance
        -- The live thinking region is keyed by marker range (thinking-range).
        -- If no region exists, one is created and inserted above the assistant text.
        -- If a region exists, it is replaced in-place via delete-region/insert.
        -- The region is styled with psi-emacs-assistant-thinking-face and
        -- prefixed "ψ⋯ ".
}

-- When a tool event arrives during an active thinking block, the live thinking
-- line is split/archived before tool output is inserted.
rule EmacsThinkingArchivedBeforeToolEvent {
    when: ToolEventPending(emacs)
    requires: emacs.thinking_in_progress != null and not IsBlank(emacs.thinking_in_progress)

    ensures:
        if ThinkingRangeLive(emacs):
            ThinkingLineArchived(emacs)
        else:
            ThinkingInProgressCleared(emacs)

    @guidance
        -- Archiving freezes the thinking-range marker pair into
        -- thinking-archived-ranges so it persists in transcript history.
        -- Clearing drops stale in-progress text when marker state drifted.
        -- After archive/clear, the next thinking delta starts a fresh block
        -- after the tool output.
}

-- At turn end (finalize), all in-progress thinking state is cleared.
-- Archived thinking ranges remain in transcript history.
rule EmacsThinkingClearedOnTurnFinalize {
    when: AssistantTurnFinalized(emacs)

    ensures: ThinkingInProgressCleared(emacs)
    ensures: ThinkingRangeCleared(emacs)
    ensures: ThinkingArchivedRangesPreserved(emacs)

    @guidance
        -- psi-emacs--clear-thinking-line removes the live buffer region and
        -- resets thinking-range + thinking-in-progress to nil.
        -- Previously archived ranges are not touched; they remain readable
        -- in the transcript as historical thinking context.
}

rule CompletionsRequestBuilt {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_completions
    requires: not IsBlank(stream.resolved_api_key)

    ensures: ProviderRequestBuilt(stream, ProviderRequest{
        url: stream.request_url,
        body: JsonEncode(CompletionsRequestBody(stream.conversation, stream.model, stream.options))
    })

    @guidance
        -- headers: {"Content-Type": "application/json",
        --           "Authorization": "Bearer " + resolved_api_key}
        -- Request body includes:
        --   model, messages, stream=true, stream_options.include_usage=true,
        --   temperature default 0, optional max_tokens/tools/reasoning_effort.
}

rule CodexRequestBuilt {
    when: OpenAIStreamRequested(stream)
    requires: stream.request_api = openai_codex_responses
    requires: not IsBlank(stream.resolved_api_key)
    requires: not IsBlank(stream.chatgpt_account_id)

    ensures: ProviderRequestBuilt(stream, ProviderRequest{
        url: stream.request_url,
        body: JsonEncode(CodexRequestBody(stream.conversation, stream.model, stream.options))
    })
    ensures: RequestBodyDoesNotContain(stream, "temperature")

    @guidance
        -- headers: {"Content-Type": "application/json",
        --           "Authorization": "Bearer " + resolved_api_key,
        --           "accept": "text/event-stream",
        --           "OpenAI-Beta": config.codex_beta_header,
        --           "originator": "psi",
        --           "chatgpt-account-id": stream.chatgpt_account_id,
        --           "id": stream.options.id,
        --           "conversation_id": stream.options.id}
        -- Codex backend rejects top-level temperature; omit even when provided.
}

rule ConversationMessageTransformsAreDeterministic {
    when: ProviderRequestBuilt(stream, request)

    ensures:
        if stream.request_api = openai_completions:
            CompletionsMessagesNormalized(stream.conversation)
    ensures:
        if stream.request_api = openai_codex_responses:
            CodexInputMessagesNormalized(stream.conversation)

    @guidance
        -- Completions normalization:
        --   user -> role=user text
        --   assistant structured -> assistant text + tool_calls with JSON arguments
        --   tool-result -> role=tool with tool_call_id and text
        -- Codex normalization:
        --   user -> input_text item
        --   assistant -> output_text and/or function_call items
        --   tool-result -> function_call_output using call_id prefix before "|"
}

rule OpenAIReasoningRemainsProjectionLocal {
    when: ProviderRequestBuilt(stream, request)

    ensures: OpenAIProjectionDoesNotRequirePriorReasoningBlocks(stream.conversation)

    @guidance
        -- Current OpenAI integrations carry continuity through standard
        -- assistant text, tool calls, and tool results. Prior reasoning output
        -- is normalized to thinking-delta events for UI/progress but is not
        -- required as a replayed conversation block in subsequent requests.
}

------------------------------------------------------------
-- Capture Callbacks
------------------------------------------------------------

rule ProviderRequestCaptureEmittedWithRedaction {
    when: ProviderRequestBuilt(stream, request)
    requires: stream.options.on_provider_request != null

    ensures: ProviderCallbackInvoked(stream.options.on_provider_request, {
        provider: "openai",
        api: stream.request_api,
        url: stream.request_url,
        request: {
            headers: RedactRequestHeaders(request.headers),
            body: ParseJsonOrString(request.body)
        }
    })
}

rule ProviderResponseCaptureEmitted {
    when: ProviderResponseObserved(stream, event)
    requires: stream.options.on_provider_response != null

    ensures: ProviderCallbackInvoked(stream.options.on_provider_response, {
        provider: "openai",
        api: stream.request_api,
        url: stream.request_url,
        event: event
    })
}

rule ProviderCaptureCallbackFailuresAreIgnored {
    when: ProviderCallbackFailed(callback, error)

    ensures: StreamContinues()
}

------------------------------------------------------------
-- Streaming Normalization
------------------------------------------------------------

rule StreamParsesOnlySseDataLines {
    when: SseLineReceived(stream, line)

    ensures:
        if not StartsWith(line, config.sse_data_prefix):
            SseLineIgnored(line)
        else if SubstringAfter(line, config.sse_data_prefix) = config.sse_done_sentinel:
            SseLineIgnored(line)
        else:
            SseDataEventProducedOrIgnoredOnJsonParseError(line)
}

rule CompletionsChunksNormalizeToExecutorEvents {
    when: CompletionsChunkReceived(stream, chunk)
    requires: stream.request_api = openai_completions

    ensures: StartEmittedOnce(stream)
    ensures: CompletionsTextDeltasEmitted(stream, chunk)
    ensures: CompletionsReasoningDeltasEmitted(stream, chunk)
    ensures: CompletionsToolCallFragmentsBufferedByIndex(stream, chunk)
    ensures: NoToolCallUiEventsEmittedBeforeTerminalBoundary(stream, chunk)

    ensures:
        if chunk.usage != null:
            CompletionsDoneWithUsageEmitted(stream, chunk)
        else if ChunkFinishReason(chunk) != null:
            CompletionsDoneWithoutUsageEmitted(stream, chunk)
}

rule CodexEventsNormalizeToExecutorEvents {
    when: CodexEventReceived(stream, event)
    requires: stream.request_api = openai_codex_responses

    ensures: StartEmittedOnce(stream)
    ensures: CodexTextDeltaEventsEmitted(stream, event)
    ensures: CodexReasoningDeltaEventsEmitted(stream, event)
    ensures: CodexToolCallFragmentsBufferedByIndex(stream, event)

    ensures:
        if EventType(event) in config.codex_completed_event_types:
            CodexDoneEventEmitted(stream, event)
        else if EventType(event) in config.codex_failed_event_types:
            CodexErrorEventEmitted(stream, event)
}

rule ToolCallsAssembledAtTerminalBoundary {
    when: TerminalBoundaryReached(stream)

    ensures: AssembleBufferedToolCalls(stream)
    ensures: BufferedToolCallsCleared(stream)
}

rule AssembledToolCallRequiresCallId {
    when: ToolCallAssembled(stream, assembled_call)
    requires: IsBlank(assembled_call.call_id)

    ensures: ToolCallAssemblyFailed(stream, assembled_call, "missing_call_id")
    ensures: Emit(StreamEvent{event_type: error, error_message: "Tool call missing call_id; cannot execute reliably"})
}

rule AssembledToolCallValidationFailureIsVisible {
    when: ToolCallAssembled(stream, assembled_call)
    requires: not IsBlank(assembled_call.call_id)
    requires: not ToolCallArgumentsValidMap(assembled_call)

    ensures: ToolCallAssemblyFailed(stream, assembled_call, "invalid_arguments")
    ensures: Emit(StreamEvent{event_type: error, error_message: "Tool call arguments invalid; expected JSON object"})
}

rule AssembledValidToolCallEmitsSingleLogicalStart {
    when: ToolCallAssembled(stream, assembled_call)
    requires: not IsBlank(assembled_call.call_id)
    requires: ToolCallArgumentsValidMap(assembled_call)

    ensures: Emit(StreamEvent{
        event_type: toolcall_start,
        content_index: assembled_call.content_index,
        id: assembled_call.call_id,
        name: assembled_call.tool_name
    })

    @guidance
        -- UI collapses tool-call streaming to one logical readiness event.
        -- Detailed tool execution progress/result is emitted by executor events.
}

rule CompletionsUsageNormalized {
    when: CompletionsDoneWithUsageEmitted(stream, chunk)

    let u = chunk.usage
    let normalized_usage = StreamUsage{
        input_tokens: u.prompt_tokens ?? 0,
        output_tokens: u.completion_tokens ?? 0,
        cache_read_tokens: 0,
        cache_write_tokens: 0,
        total_tokens: u.total_tokens ?? (u.prompt_tokens ?? 0) + (u.completion_tokens ?? 0),
        cost: CalculateCost(stream.model, {
            input_tokens: u.prompt_tokens ?? 0,
            output_tokens: u.completion_tokens ?? 0,
            cache_read_tokens: 0,
            cache_write_tokens: 0,
            total_tokens: u.total_tokens ?? (u.prompt_tokens ?? 0) + (u.completion_tokens ?? 0)
        })
    }

    ensures: NormalizedUsageForChunk(chunk) = normalized_usage
}

rule CodexUsageNormalized {
    when: CodexDoneEventEmitted(stream, event)
    requires: event.response.usage != null

    let u = event.response.usage
    let cached = u.input_tokens_details.cached_tokens ?? 0
    let normalized_usage = StreamUsage{
        input_tokens: max(0, (u.input_tokens ?? 0) - cached),
        output_tokens: u.output_tokens ?? 0,
        cache_read_tokens: cached,
        cache_write_tokens: 0,
        total_tokens: u.total_tokens ?? (u.input_tokens ?? 0) + (u.output_tokens ?? 0),
        cost: CalculateCost(stream.model, {
            input_tokens: max(0, (u.input_tokens ?? 0) - cached),
            output_tokens: u.output_tokens ?? 0,
            cache_read_tokens: cached,
            cache_write_tokens: 0,
            total_tokens: u.total_tokens ?? (u.input_tokens ?? 0) + (u.output_tokens ?? 0)
        })
    }

    ensures: NormalizedUsageForCodexEvent(event) = normalized_usage
}

rule CodexStatusMappedToDoneReason {
    when: CodexDoneEventEmitted(stream, event)

    let status = event.response.status
    ensures:
        if status = "incomplete":
            DoneReason(event) = length
        else if status in {"failed", "cancelled"}:
            DoneReason(event) = error
        else:
            DoneReason(event) = stop
}

rule StreamErrorsNormalized {
    when: ProviderRequestFailed(stream, error)

    ensures: Emit(StreamEvent{
        event_type: error,
        error_message: ErrorMessageWithStatusAndRequestId(error),
        http_status: HttpStatusOrNull(error)
    })
}

rule OpenAITransportCloseEmitsDoneIfNotTerminal {
    when: ProviderTransportClosed(stream)
    requires: stream.done = false

    ensures: StartEmittedOnce(stream)
    ensures: Emit(StreamEvent{event_type: done, reason: stop})
}

surface OpenAIProviderApi {
    facing executor: AgentExecutor

    provides:
        OpenAIStreamRequested(stream)

    exposes:
        StreamEvent
        StreamUsage
}

open question "Should completions and codex emit identical tool-call ids to simplify downstream transcript diffing?"
