-- allium: 1

-- skills.allium
-- Skill discovery, validation, progressive disclosure, and invocation.

value SkillFrontmatter {
    name: String
    description: String
    license: String?
    compatibility: String?
    metadata: Map<String, String>?
    allowed_tools: Set<String>?
    disable_model_invocation: Boolean?
}

value SkillValidationResult {
    valid: Boolean
    warnings: Set<String>
    errors: Set<String>
}

value SkillExpansion {
    content: String
    skill_name: String
}

entity Skill {
    name: String
    description: String
    file_path: String
    base_dir: String
    source: user | project | package | settings | cli
    disable_model_invocation: Boolean

    license: String?
    compatibility: String?
    allowed_tools: Set<String>?

    is_available_to_model: not disable_model_invocation
}

config {
    global_skills_dirs: Set<String> = {"~/.psi/agent/skills", "~/.agents/skills"}
    project_skills_dirs: Set<String> = {".psi/skills", ".agents/skills"}
    name_max_length: Integer = 64
    description_max_length: Integer = 1024
    compatibility_max_length: Integer = 500
}

rule SkillsDiscovered {
    when: SkillsDiscoveryRequested(sources)

    let paths = OrderedUnion(
        GlobalSkills(config.global_skills_dirs),
        ProjectSkills(config.project_skills_dirs),
        PackageSkills(),
        SettingsSkills(),
        CliSkills()
    )

    ensures:
        for path in paths:
            parsed = SkillParsed(path)
            validation = SkillValidated(parsed)
            if validation.valid:
                if not exists Skill with name = parsed.name:
                    Skill.created(
                        name: parsed.name,
                        description: parsed.description,
                        file_path: path.absolute,
                        base_dir: path.parent,
                        source: path.source,
                        disable_model_invocation: parsed.disable_model_invocation ?? false,
                        license: parsed.license,
                        compatibility: parsed.compatibility,
                        allowed_tools: parsed.allowed_tools
                    )
}

rule SkillsDisabledByFlag {
    when: SkillsDiscoveryRequested(sources)
    requires: sources.no_skills = true

    ensures: OnlyCliSkillsLoaded()
}

rule SkillParsed {
    when: SkillParseRequested(path)

    let raw = ReadFile(path)
    let frontmatter = ExtractYamlFrontmatter(raw)

    requires: frontmatter.name != null
    requires: frontmatter.description != null

    ensures: result = SkillFrontmatter{
        name: frontmatter.name,
        description: frontmatter.description,
        license: frontmatter.license,
        compatibility: frontmatter.compatibility,
        metadata: frontmatter.metadata,
        allowed_tools: frontmatter.allowed_tools,
        disable_model_invocation: frontmatter.disable_model_invocation
    }
}

rule SkillValidated {
    when: SkillValidated(parsed)

    let warnings = {}
    let errors = {}

    ensures:
        if parsed.name.length > config.name_max_length:
            warnings = warnings + {"Name exceeds 64 characters"}

    ensures:
        if not MatchesRegex(parsed.name, "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"):
            warnings = warnings + {"Name contains invalid characters"}

    ensures:
        if Contains(parsed.name, "--"):
            warnings = warnings + {"Name has consecutive hyphens"}

    ensures:
        if parsed.name != parsed.parent_dir_name:
            warnings = warnings + {"Name does not match parent directory"}

    ensures:
        if parsed.description = null:
            errors = errors + {"Missing description"}

    ensures:
        if parsed.description != null and parsed.description.length > config.description_max_length:
            warnings = warnings + {"Description exceeds 1024 characters"}

    ensures:
        if parsed.compatibility != null and parsed.compatibility.length > config.compatibility_max_length:
            warnings = warnings + {"Compatibility exceeds 500 characters"}

    ensures: result = SkillValidationResult{
        valid: errors.count = 0,
        warnings: warnings,
        errors: errors
    }
}

rule SkillNameCollision {
    when: Skill.created(name, description, file_path, base_dir, source, disable_model_invocation, license, compatibility, allowed_tools)
    requires: exists Skill with name = name

    ensures: SkillCreationRejected(name)
    ensures: Warning.emitted("Skill name collision: " + name)
}

rule SkillsInSystemPrompt {
    when: SystemPromptSkillsAssembled(skills)

    let visible = skills where is_available_to_model
    ensures: result = VisibleSkillDescriptors(visible)
}

rule SkillCommandExpanded {
    when: SkillCommandExpansionRequested(text)
    requires: StartsWith(text, "/skill:")

    let skill_name = SkillNameFromCommand(text)
    let skill = Skill with name = skill_name
    requires: skill != null

    let content = ReadFile(skill.file_path)
    let args = CommandTail(text)

    ensures: result = SkillExpansion{
        content: "<skill name=\"" + skill.name + "\" location=\"" + skill.file_path + "\">\n" + content + "\n</skill>\n\n" + args,
        skill_name: skill.name
    }
}

rule SkillNotFound {
    when: SkillCommandExpansionRequested(text)
    requires: StartsWith(text, "/skill:")

    let skill_name = SkillNameFromCommand(text)
    requires: not exists Skill with name = skill_name

    ensures: Error.emitted("Skill not found: " + skill_name)
}

actor User {
    identified_by: id = "human-operator"
}

surface SkillApi {
    facing caller: User

    exposes:
        Skill.name
        Skill.description
        Skill.source
        Skill.is_available_to_model
        Skill.disable_model_invocation

    provides:
        SkillCommandExpansionRequested(text)
        SkillsDiscoveryRequested(sources)

    @guidance
        -- /skill:name is available with autocomplete.
        -- disable_model_invocation hides a skill from system prompt but keeps direct invocation.
        -- Discovery supports direct .md files at root and recursive SKILL.md files in subdirs.
        -- --no-skills disables discovery except explicit CLI skill paths.
}

deferred ExtractYamlFrontmatter.parse
deferred SkillContentReader.read

open question "Should skill name collisions be configurable (warn, error, or last-wins)?"
open question "Should allowed-tools in frontmatter auto-activate tools, or remain documentation only?"
open question "Should cross-harness skill loading relax validation for non-standard frontmatter fields?"
