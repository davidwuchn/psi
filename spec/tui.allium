deferred KillRing.operations         -- see: spec/tui/kill-ring.allium
deferred UndoStack.operations        -- see: spec/tui/undo-stack.allium
deferred CombinedAutocompleteProvider.suggest   -- see: spec/tui/autocomplete.allium
