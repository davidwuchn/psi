-- allium: 1

-- subagent-widget-ui.allium
-- Subagent widget UI projection and result-message rendering semantics.
-- Distilled from tests/implementation and refined by elicitation.

use "./subagent-widget-extension.allium" as subagent
use "./ui-extension-points.allium" as ui
use "./ui-interactive-widgets.allium" as ui_widgets
use "./session-core.allium" as session_core
use "./tui.allium" as tui

value SubagentWidgetRenderOptions {
    task_preview_chars: Integer?
    detail_preview_chars: Integer?
    list_task_preview_chars: Integer?
    result_text_max_chars: Integer?
}

value EffectiveSubagentWidgetRenderOptions {
    task_preview_chars: Integer
    detail_preview_chars: Integer
    list_task_preview_chars: Integer
    result_text_max_chars: Integer
}

config {
    default_task_preview_chars: Integer = 52
    default_detail_preview_chars: Integer = 100
    default_list_task_preview_chars: Integer = 70
    default_result_text_max_chars: Integer = 8000
    refresh_after_workflow_callback_ms: Integer = 30
}

rule SubagentWidgetRenderOptionsDefault {
    when: SubagentWidgetProjectionRequested(session, extension_id, workflow_id, request_options)

    ensures: EffectiveRenderOptions(request_options) = EffectiveSubagentWidgetRenderOptions{
        task_preview_chars: FirstPositiveInteger(request_options.task_preview_chars, config.default_task_preview_chars),
        detail_preview_chars: FirstPositiveInteger(request_options.detail_preview_chars, config.default_detail_preview_chars),
        list_task_preview_chars: FirstPositiveInteger(request_options.list_task_preview_chars, config.default_list_task_preview_chars),
        result_text_max_chars: FirstPositiveInteger(request_options.result_text_max_chars, config.default_result_text_max_chars)
    }
}

rule SubagentWidgetRenderOptionsArePerRequest {
    when: SubagentWidgetProjectionRequested(session, extension_id, workflow_id, request_options)

    ensures: WidgetProjectionFor(workflow_id).render_options = EffectiveRenderOptions(request_options)
    ensures: DifferentRequestsMayUseDifferentRenderOptions(workflow_id)
}

rule VisibleSubagentWidgetsAreChildSessionsOfCurrentSession {
    when: SubagentWidgetsRefreshed(session, extension_id)

    ensures: ForEach(VisibleSubagentWorkflowIds(session, extension_id),
                     sid -> session_core/ChildSessionRelation(
                              parent: CurrentSession(session),
                              child: SubagentSessionForWorkflow(extension_id, sid),
                              relation: subagent))
}

rule OneWidgetPerVisibleSubagentWorkflow {
    when: SubagentWidgetsRefreshed(session, extension_id)

    ensures: ForEach(VisibleSubagentWorkflowIds(session, extension_id),
                     sid -> WidgetExists(session.ui_state.widgets, extension_id, "sub-" + sid))

    ensures: ForEach(WidgetIdsForExtension(session.ui_state.widgets, extension_id),
                     wid -> wid startsWith "sub-" implies
                            WorkflowIsVisibleInCurrentSession(session, extension_id, RemovePrefix(wid, "sub-")))
}

rule SubagentWidgetsOrderedMostRecentFirst {
    when: SubagentWidgetsRefreshed(session, extension_id)

    ensures: WidgetOrderForExtension(session.ui_state.widgets, extension_id) =
             SortMostRecentFirst(WidgetIdsForExtension(session.ui_state.widgets, extension_id),
                                 recency_key: {workflow.started_at, workflow.id})
}

rule SessionSwitchReprojectsOnlyChildSubagentWidgets {
    when: SessionSwitched(session)

    ensures: ForEach(WidgetIdsForExtension(session.ui_state.widgets, any_extension),
                     wid -> wid startsWith "sub-" implies
                            WidgetReferencesVisibleChildWorkflow(session, any_extension, wid))
    ensures: NoWidgetForNonChildSubagentWorkflow(session.ui_state.widgets, CurrentSession(session))
}

rule SubagentWidgetPlacementByUiKind {
    when: SubagentWidgetProjected(session, ui_runtime, extension_id, subagent_id)

    ensures:
        if ui_runtime.ui_kind = emacs:
            WidgetPlacementOf(session.ui_state.widgets, extension_id, "sub-" + subagent_id) = below_editor
        else:
            WidgetPlacementOf(session.ui_state.widgets, extension_id, "sub-" + subagent_id) = above_editor
}

rule SubagentWidgetPhaseLabelMapping {
    when: PhaseLabelRequested(phase)

    ensures:
        if phase = running: PhaseLabel(phase) = "RUN"
        else if phase = done: PhaseLabel(phase) = "DONE"
        else if phase = error: PhaseLabel(phase) = "ERR"
        else if phase = idle: PhaseLabel(phase) = "IDLE"
        else: PhaseLabel(phase) = Uppercase(ToString(phase))
}

rule SubagentWidgetStatusIconMapping {
    when: StatusIconRequested(phase)

    ensures:
        if phase = running: StatusIcon(phase) = "●"
        else if phase = done: StatusIcon(phase) = "✓"
        else if phase = error: StatusIcon(phase) = "✗"
        else if phase = idle: StatusIcon(phase) = "○"
        else: StatusIcon(phase) = "?"
}

rule RunningSubagentElapsedSecondsFromNow {
    when: ElapsedSecondsRequested(workflow)
    requires: workflow.running = true
    requires: workflow.started_at != null

    ensures: ElapsedSeconds(workflow) = floor((now - workflow.started_at) / 1000)
}

rule TerminalSubagentElapsedSecondsFromSnapshot {
    when: ElapsedSecondsRequested(workflow)
    requires: workflow.running = false or workflow.started_at = null

    ensures: ElapsedSeconds(workflow) = floor(workflow.elapsed_ms / 1000)
}

rule SubagentWidgetHeaderLineFormat {
    when: SubagentWidgetLineComposed(workflow, line_index: 0, render_options)

    ensures: line =
      StatusIcon(workflow.phase)
      + " Subagent #" + workflow.id
      + " [" + PhaseLabel(workflow.phase) + "]"
      + " · T" + ToString(workflow.turn_count)
      + " · " + ToString(ElapsedSeconds(workflow)) + "s"
      + Optional(" · @" + workflow.agent_name)
      + Optional(" · fork" when workflow.fork_session = true)
      + " · " + TaskPreview(workflow.task, render_options.task_preview_chars)
}

rule SubagentWidgetErrorSummaryLinePrecedence {
    when: ErrorSummaryLineRequested(workflow)

    ensures: ErrorSummaryLine(workflow) =
             FirstNonBlank({
               CleanErrorPrefix(workflow.error_message),
               CleanErrorPrefix(LastNonBlankLine(workflow.last_text))
             })
}

rule SubagentWidgetErrorDetailLine {
    when: SubagentWidgetDetailLineComposed(workflow, render_options)
    requires: workflow.error = true
    requires: ErrorSummaryLine(workflow) != ""

    ensures: DetailLine(workflow) =
             "  ! " + TaskPreview(ErrorSummaryLine(workflow), render_options.detail_preview_chars)
}

rule SubagentWidgetProgressOrResultDetailLine {
    when: SubagentWidgetDetailLineComposed(workflow, render_options)
    requires: workflow.error = false
    requires: LastNonBlankLine(workflow.last_text) != ""

    ensures:
        if workflow.done = true:
            DetailLine(workflow) = "  ↳ " + TaskPreview(LastNonBlankLine(workflow.last_text), render_options.detail_preview_chars)
        else:
            DetailLine(workflow) = "  … " + TaskPreview(LastNonBlankLine(workflow.last_text), render_options.detail_preview_chars)
}

rule SubagentWidgetActionLineForTerminalStates {
    when: SubagentWidgetActionLineComposed(workflow)
    requires: workflow.running = false
    requires: workflow.done = true or workflow.error = true

    ensures: ActionLine(workflow).text = "  /subcont " + workflow.id + " <prompt> · ✕ remove"
    ensures: ActionLine(workflow).action.type = command
    ensures: ActionLine(workflow).action.command = "/subrm " + workflow.id
}

rule SubagentWidgetActionLineAbsentWhileRunning {
    when: SubagentWidgetActionLineComposed(workflow)
    requires: workflow.running = true

    ensures: ActionLine(workflow) = null
}

rule TerminalSubagentWidgetsPersistUntilExplicitRemove {
    when: SubagentWidgetsRefreshed(session, extension_id)

    ensures: ForEach(SubagentWorkflowsInPhase(session, extension_id, {done, error}),
                     wf -> WidgetExists(session.ui_state.widgets, extension_id, "sub-" + wf.id)
                           until subagent/SubagentToolCalled(action: remove, args: {id: ParseInt(wf.id)}))
}

rule SubagentWidgetActionDispatchRemovesWorkflow {
    when: ui_widgets/WidgetActionActivated(session, ui_runtime, extension_id, widget_id, line_index)
    requires: line = WidgetLine(session.ui_state.widgets, extension_id, widget_id, line_index)
    requires: line.action.command startsWith "/subrm "

    ensures: subagent/SubagentToolCalled(action: remove, args: {id: ParseInt(CommandTail(line.action.command))})
}

rule SubagentWidgetRefreshAfterWorkflowCallbacks {
    when: SubagentWorkflowCallbackFired(session, extension_id, workflow_id, kind)
    requires: kind in {on_start, on_finished}

    ensures: SubagentWidgetsRefreshScheduled(session, extension_id, delay_ms: config.refresh_after_workflow_callback_ms)
}

rule SubagentWidgetRefreshUsesCommittedWorkflowSnapshot {
    when: SubagentWidgetsRefreshScheduled(session, extension_id, delay_ms)
    requires: delay_ms >= config.refresh_after_workflow_callback_ms

    ensures: WidgetProjectionUsesCommittedWorkflowPhase(session, extension_id)
}

rule TuiKeepsTextOnlyWidgetSemanticsForSubagents {
    when: SubagentWidgetProjected(session, ui_runtime, extension_id, subagent_id)
    requires: ui_runtime.ui_kind = tui

    ensures: ui_runtime.capability.kind = text_only
    ensures: ForEach(WidgetLines(session.ui_state.widgets, extension_id, "sub-" + subagent_id),
                     line -> line.action = null or ActionBindingNotCreated(ui_runtime, extension_id, "sub-" + subagent_id, line))
}

rule SubagentResultMessageHeadingIncludesAgentAndForkWhenPresent {
    when: SubagentResultMessageEmitted(subagent_id, prompt, turn_count, elapsed_ms, result_text, agent_name, fork_session)

    ensures: HeadingLine =
             "Subagent #" + ToString(subagent_id)
             + Optional(" (Turn " + ToString(turn_count) + ")" when turn_count > 1)
             + Optional(" (@" + agent_name + ")" when agent_name != null and agent_name != "")
             + Optional(" [fork]" when fork_session = true)
             + " finished \"" + prompt + "\" in " + ToString(floor(elapsed_ms / 1000)) + "s"
}

rule SubagentResultMessageContainsCanonicalBody {
    when: SubagentResultMessageEmitted(subagent_id, prompt, turn_count, elapsed_ms, result_text, agent_name, fork_session)

    ensures: MessageText startsWith HeadingLine
    ensures: MessageText contains "\n\nResult:\n"
}

rule SubagentResultMessageAppliesPerRequestBodyLimit {
    when: SubagentResultMessageEmitted(subagent_id, prompt, turn_count, elapsed_ms, result_text, agent_name, fork_session)

    ensures: MessageText = TruncateBody(MessageText, EffectiveRenderOptions(CurrentRenderRequest()).result_text_max_chars)
}

rule SubagentResultMessageRenderedRichlyInTui {
    when: TuiMessageRenderRequested(tui_runtime, message, width)
    requires: message.role = assistant
    requires: message.custom_type = "subagent-result"

    ensures: RenderedTitle(message) = "ψ: ⎇ Subagent Result"
    ensures: RenderedHeading(message) = FirstLineOrDefault(message.text, "Subagent result")
    ensures: RenderedBody(message) = MarkdownRender(RemainingLinesAfterHeading(message.text), max_width: width - 4)
}
