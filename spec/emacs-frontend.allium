-- allium: 1

-- emacs-frontend.allium
-- Emacs process-buffer frontend behavior over EDN RPC.

use "./coding-agent.allium" as coding
use "./agent-turn-interrupts.allium" as turn_interrupts
use "./ui-extension-points.allium" as ui
use "./ui-interactive-widgets.allium" as ui_widgets
use "./rpc-edn.allium" as rpc
use "./tool-output-display.allium" as tool_display
use "./tool-output-rendering.allium" as tool_render
use "./prompt-input-autocomplete.allium" as prompt_autocomplete
use "./emacs-prompt-completion.allium" as emacs_prompt_completion
use "./prompt-slash-commands.allium" as slash_commands
use "./frontend-action-rpc.allium" as frontend_actions
use "./emacs-footer.allium" as emacs_footer
use "./session-management.allium" as session_mgmt

value FrontendCapabilities {
    prompting: Boolean
    streaming_text: Boolean
    tool_lifecycle: Boolean
    session_lifecycle: Boolean
    model_thinking_controls: Boolean
    compaction_controls: Boolean
    oauth: Boolean
    extension_ui: Boolean
    footer: Boolean
    command_discovery: Boolean
}

value EmacsKeymap {
    send: String
    queue: String
    interrupt: String
    reconnect: String
    toggle_tool_output: String
    set_model: String
    cycle_model_next: String
    cycle_model_prev: String
    set_thinking_level: String
    cycle_thinking_level: String
    queue_prefix: String
}

value HeaderLineView {
    transport: disconnected | connecting | ready
    run_state: idle | streaming | interrupt_pending | reconnecting | error
    tool_output_view: collapsed | expanded
    model_label: String?
}

entity AssistantStreamState {
    in_progress_text: String?
    in_progress_thinking_text: String?
    completed_blocks: Set<String>
}

entity ToolRow {
    tool_call_id: String
    tool_name: String
    status: pending | running | success | error
    streamed_output: String
    ansi_faces_applied: Boolean
}

entity EmacsProcessBuffer {
    buffer_name: String
    major_mode: markdown | text
    transcript_editable: Boolean
    transcript_banner: String?
    draft_text: String
    has_active_region: Boolean
    active_region_text: String?
    has_pending_edits: Boolean
    cursor_in_input_area: Boolean
}

entity EmacsFrontend {
    session: coding/CodingAgentRuntime
    rpc: rpc/RpcEndpoint

    buffer: EmacsProcessBuffer
    assistant: AssistantStreamState
    tool_rows: Set<ToolRow>
    header_line: HeaderLineView
    keymap: EmacsKeymap

    tool_output_view: collapsed | expanded
    footer_projection: String?

    run_state: idle | streaming | interrupt_pending | reconnecting | error
    last_error: String?

    auto_connect: Boolean
    single_subprocess: Boolean
    reconnect_policy: manual | auto
    clear_buffer_on_reconnect: Boolean

    subscribed_topics: Set<String>
    capabilities: FrontendCapabilities
}

config {
    send_key: String = "C-c RET"
    queue_key: String = "C-c C-q"
    interrupt_key: String = "C-c C-c"
    reconnect_key: String = "C-c C-r"
    toggle_tool_output_key: String = "C-c C-t"

    set_model_key: String = "C-c m m"
    cycle_model_next_key: String = "C-c m n"
    cycle_model_prev_key: String = "C-c m p"
    set_thinking_level_key: String = "C-c m t"
    cycle_thinking_level_key: String = "C-c m c"

    queue_prefix: String = "C-u"
    stream_timeout_seconds: Integer = 45
    default_tool_output_view: collapsed | expanded = collapsed
}

rule ParityProfileIsDefault {
    when: EmacsFrontendInitialized(frontend)

    ensures: frontend.auto_connect = true
    ensures: frontend.single_subprocess = true
    ensures: frontend.reconnect_policy = manual
    ensures: frontend.clear_buffer_on_reconnect = true

    ensures: frontend.buffer.transcript_editable = true
    ensures: frontend.tool_output_view = config.default_tool_output_view
    ensures: frontend.run_state = idle
    ensures: frontend.last_error = null

    ensures: frontend.capabilities = FrontendCapabilities{
        prompting: true,
        streaming_text: true,
        tool_lifecycle: true,
        session_lifecycle: true,
        model_thinking_controls: true,
        compaction_controls: true,
        oauth: true,
        extension_ui: true,
        footer: true,
        command_discovery: true
    }
}

rule ComposeAutocompleteUsesSharedContract {
    when: EmacsFrontendInitialized(frontend)

    ensures: UsesContract(frontend, prompt_autocomplete/PromptAutocompleteContract)
    ensures: UsesContract(frontend, emacs_prompt_completion/EmacsPromptCompletionArchitecture)
}

rule SlashExecutionUsesSharedContracts {
    when: PromptSubmissionRequested(frontend, text)
    requires: StartsWith(Trim(text), "/")

    ensures: UsesContract(frontend, slash_commands/PromptSlashCommandContract)
    ensures: UsesContract(frontend, frontend_actions/FrontendActionRpcApi)
}

rule StartupBufferSeedsBannerAndInputFocus {
    when: EmacsFrontendInitialized(frontend)

    ensures: frontend.buffer.transcript_banner = "ψ"
    ensures: frontend.buffer.cursor_in_input_area = true
}

rule AutoConnectStartsRpc {
    when: EmacsFrontendInitialized(frontend)
    requires: frontend.auto_connect = true

    ensures: RpcStartRequested(frontend.rpc)
    ensures: frontend.run_state = reconnecting
}

rule HandshakeAndSubscribeOnConnect {
    when: RpcConnected(frontend.rpc)

    ensures: rpc/HandshakeRequested(frontend.rpc, BuildClientInfo(frontend))
    ensures: rpc/SubscribeRequested(frontend.rpc, DefaultTopicSet())
    ensures: frontend.run_state = idle
}

rule SendKeySubmitsPrompt {
    when: KeyPressed(frontend, source_key)
    requires: source_key in {config.send_key, config.queue_key}

    ensures: PromptSubmissionRequested(frontend, ComposedText(frontend))
}

rule InterruptKeyRequestsDeferredInterrupt {
    when: KeyPressed(frontend, source_key)
    requires: source_key = config.interrupt_key

    ensures: turn_interrupts/InterruptRequested(frontend.session.session)
    ensures: frontend.run_state = interrupt_pending
}

rule ToggleToolOutputView {
    when: KeyPressed(frontend, source_key)
    requires: source_key in {config.toggle_tool_output_key, "toggle_tool_output_view"}

    ensures:
        if frontend.tool_output_view = collapsed:
            frontend.tool_output_view = expanded
        else:
            frontend.tool_output_view = collapsed

    ensures: tool_display/SetToolsExpanded(frontend.session.session, frontend.tool_output_view = expanded)
}

rule ModelAndThinkingControlsDispatch {
    when: ModelControlRequested(frontend, control, args)
    requires: control in {"set_model", "cycle_model", "set_thinking_level", "cycle_thinking_level"}

    ensures: RpcModelControlRequested(frontend.rpc, control, args)
}

rule AssistantStreamingUpdatesTranscript {
    when: RpcEventReceived(frontend.rpc, event_name, payload)
    requires: event_name in {"assistant/delta", "assistant/thinking-delta", "assistant/message"}

    ensures: ApplyAssistantStreamEvent(frontend.assistant, event_name, payload)
}

rule ToolLifecycleRendersViaSharedContracts {
    when: RpcEventReceived(frontend.rpc, event_name, payload)
    requires: event_name in {"tool/start", "tool/executing", "tool/update", "tool/result"}

    ensures: UsesContract(frontend, tool_display/ToolOutputDisplayApi)
    ensures: UsesContract(frontend, tool_render/ToolOutputRenderer)
}

rule ToolStartCanProjectTerminalAssemblyContext {
    when: RpcEventReceived(frontend.rpc, "tool/start", payload)

    ensures: ToolStartAlwaysHasIdentity(payload, required: {"tool-id", "tool-name"})
    ensures: ToolStartMayIncludeArguments(payload, optional: {"arguments", "parsed-args"})
}

rule FooterProjectionUsesSharedContract {
    when: RpcEventReceived(frontend.rpc, "footer/updated", payload)

    ensures: UsesContract(frontend, emacs_footer/EmacsFooterProjectionContract)
}

rule ExtensionUiUsesSharedContract {
    when: RpcEventReceived(frontend.rpc, event_name, payload)
    requires: event_name in {"ui/dialog-requested", "ui/widgets-updated", "ui/status-updated", "ui/notification"}

    ensures: UsesContract(frontend, ui/ExtensionUI)
    ensures: UsesContract(frontend, ui/ExtensionUIQuery)
}

rule FrontendActionEventsUseSharedContract {
    when: RpcEventReceived(frontend.rpc, "ui/frontend-action-requested", payload)

    ensures: UsesContract(frontend, frontend_actions/FrontendActionRpcApi)
}

rule CommandResultEventsAppendTranscriptOrApplyTerminalAction {
    when: RpcEventReceived(frontend.rpc, "command-result", payload)

    ensures: CommandResultHandled(frontend, payload)
}

rule InteractiveWidgetsUseSharedContract {
    when: RpcEventReceived(frontend.rpc, "ui/widgets-updated", payload)

    ensures: UsesContract(frontend, ui_widgets/InteractiveWidgetProjection)
}

rule NewSessionResetPreservesBannerBeforeReplay {
    when: SlashCommandHandled(frontend, command: "/new")

    ensures: frontend.buffer.transcript_banner = "ψ"
    ensures: frontend.buffer.cursor_in_input_area = true
}

rule ReconnectKeyRestartsTransport {
    when: KeyPressed(frontend, source_key)
    requires: source_key = config.reconnect_key

    ensures: RpcRestartRequested(frontend.rpc)
    ensures: frontend.run_state = reconnecting
}

surface EmacsFrontendApi {
    facing client: rpc/RpcClient

    context frontend: EmacsFrontend

    exposes:
        frontend.run_state
        frontend.tool_output_view
        frontend.header_line
        frontend.footer_projection

    provides:
        EmacsFrontendInitialized(frontend)
        PromptSubmissionRequested(frontend, text)
        KeyPressed(frontend, source_key)
        RpcEventReceived(frontend.rpc, event_name, payload)
        RpcConnected(frontend.rpc)
        ModelControlRequested(frontend, control, args)

    related:
        rpc/RpcTransportApi
        rpc/RpcEventStream

    @guidance
        -- One subprocess and one dedicated process buffer per frontend instance.
        -- Auto-connect lifecycle is start -> handshake -> subscribe.
        -- Streaming assistant/tool events update transcript incrementally.
        -- Tool output collapse/expand is global per frontend view.
}

-- ── Session tree widget ────────────────────────────────────────────────────

rule HostUpdatedRendersSessionTreeWidget {
    when: RpcEventReceived(frontend.rpc, "host/updated", payload)

    ensures: SessionTreeWidgetProjected(frontend, payload.sessions, payload.active_session_id)
    ensures: ui/WidgetSet(
        session: frontend.session,
        extension_id: "psi-session",
        widget_id: "session-tree",
        placement: "left",
        content: SessionTreeWidgetLines(payload.sessions, payload.active_session_id)
    )
}

rule SessionTreeWidgetLineIsActive {
    when: SessionTreeWidgetLines(sessions, active_session_id)
    requires: exists slot in sessions where slot.id = active_session_id

    ensures: ActiveSlotLine(slot) = WidgetLine {
        text: SessionDisplayName(slot) + " ← active",
        action: null
    }
}

rule SessionTreeWidgetLineIsInactive {
    when: SessionTreeWidgetLines(sessions, active_session_id)
    requires: exists slot in sessions where slot.id != active_session_id

    ensures: InactiveSlotLine(slot) = WidgetLine {
        text: SessionDisplayName(slot),
        action: WidgetAction { type: command, command: "/tree " + slot.id }
    }
}

rule SessionTreeWidgetLineShowsStreamingState {
    when: SessionTreeWidgetLines(sessions, active_session_id)
    requires: exists slot in sessions where slot.is_streaming = true

    ensures: SlotLineText(slot) = SessionDisplayName(slot) + " [streaming]"
}

rule SessionDisplayNameUsesNameOrFallback {
    when: SessionDisplayName(slot)
    requires: slot.name != null

    ensures: SessionDisplayName(slot) = slot.name
}

rule SessionDisplayNameFallsBackToIdPrefix {
    when: SessionDisplayName(slot)
    requires: slot.name = null

    ensures: SessionDisplayName(slot) = "(session " + StringPrefix(slot.id, 8) + ")"
}

rule SessionTreeWidgetReflectsParentChildIndent {
    when: SessionTreeWidgetLines(sessions, active_session_id)
    requires: exists slot in sessions where slot.parent_session_id != null
    requires: exists s in sessions where s.id = slot.parent_session_id

    ensures: SlotLineIndent(slot) = SlotLineIndent(s) + 2
}

rule HostUpdatedOnSubscribeInitializesWidget {
    when: RpcEventReceived(frontend.rpc, "host/updated", payload)
    requires: frontend.run_state = connecting

    ensures: SessionTreeWidgetProjected(frontend, payload.sessions, payload.active_session_id)
}

-- ── frontend action requests ───────────────────────────────────────────────

rule SessionTreeFrontendActionUsesCompletingRead {
    when: frontend_actions/FrontendActionEventReceived(frontend, request)
    requires: request.action_name = "session-tree-selector"

    ensures: NativeSelectorKind(frontend, request) = completing_read
    ensures: FrontendActionCandidates(frontend, request) = request.payload.candidates
}

rule ResumeFrontendActionUsesCompletingRead {
    when: frontend_actions/FrontendActionEventReceived(frontend, request)
    requires: request.action_name = "resume-selector"

    ensures: NativeSelectorKind(frontend, request) = completing_read
    ensures: FrontendActionCandidates(frontend, request) = request.payload.candidates
}

rule ModelFrontendActionUsesCompletingRead {
    when: frontend_actions/FrontendActionEventReceived(frontend, request)
    requires: request.action_name = "model-picker"

    ensures: NativeSelectorKind(frontend, request) = completing_read
    ensures: FrontendActionCandidates(frontend, request) = request.payload.candidates
}

rule ThinkingFrontendActionUsesCompletingRead {
    when: frontend_actions/FrontendActionEventReceived(frontend, request)
    requires: request.action_name = "thinking-picker"

    ensures: NativeSelectorKind(frontend, request) = completing_read
    ensures: FrontendActionCandidates(frontend, request) = request.payload.candidates
}

rule CompletedFrontendActionSendsRpcResult {
    when: frontend_actions/FrontendActionCompleted(frontend, value)

    ensures: RpcRequestSent(frontend.rpc, "frontend_action_result", {value: value})
}

rule CancelledFrontendActionSendsRpcResult {
    when: frontend_actions/FrontendActionCancelled(frontend)

    ensures: RpcRequestSent(frontend.rpc, "frontend_action_result", {value: null, status: "cancelled"})
}

surface EmacsFrontendActionApi {
    facing client: rpc/RpcClient

    context frontend: EmacsFrontend

    provides:
        frontend_actions/FrontendActionEventReceived(frontend, request)
        frontend_actions/FrontendActionCompleted(frontend, value)
        frontend_actions/FrontendActionCancelled(frontend)

    @guidance
        -- Emacs renders frontend actions with native completing-read style affordances.
        -- Candidate lists are supplied entirely by the backend in the action payload.
        -- Overlapping frontend-action requests are handled by the frontend; the newest request wins.
        -- This replaces prior frontend-local slash routing for /tree, /resume, /model, and /thinking.
}

open question "Should reconnect optionally offer session selection before clearing buffer?"
open question "In markdown mode, should image handling default to inline display or file-link fallback?"
