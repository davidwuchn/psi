-- prompt-templates.allium
--
-- Scope: Prompt template discovery, parsing, argument expansion, and invocation.
--
-- Prompt templates are Markdown snippets that expand into full prompts.
-- The user types /name in the editor to invoke a template, where name
-- is the filename without .md.
--
-- Includes:
--   PromptTemplate entity — structure, metadata, source tracking
--   Discovery — loading from global, project, package, CLI paths
--   Parsing — frontmatter extraction, description fallback
--   Argument expansion — positional args, $@, slicing
--   Invocation — /name dispatch, autocomplete surface
--
-- Excludes:
--   Skill expansion (see coding-agent.allium SkillCommandExpanded)
--   System prompt assembly (see coding-agent.allium SystemPromptBuilt)
--   Extension command dispatch (see coding-agent.allium ExtensionCommandExecuted)

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value TemplateFrontmatter {
    description: String?
}

value ExpandedPrompt {
    content: String
    source_template: String     -- template name that produced this
}

value ArgumentSlice {
    start: Integer              -- 1-indexed
    length: Integer?            -- null = rest of args
}

------------------------------------------------------------
-- Entity
------------------------------------------------------------

entity PromptTemplate {
    name: String                -- derived from filename without .md
    description: String         -- from frontmatter, or first non-empty line
    content: String             -- body after frontmatter; contains $1 $2 $@ placeholders
    source: user | project | package | cli | settings
    filePath: String            -- absolute path to the .md file

    -- Derived
    has_placeholders: content.contains("$")
    placeholder_count: count of distinct $N references in content
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    global_prompts_dir: Path = ~/.psi/agent/prompts
    project_prompts_dir: Path = .psi/prompts
    discovery_recursive: Boolean = false
}

------------------------------------------------------------
-- Discovery
------------------------------------------------------------

rule TemplatesDiscovered {
    -- At startup and on reload, templates are loaded from all sources.
    -- Later sources do NOT override earlier ones (first-discovered wins).
    when: TemplatesDiscovered(sources)

    let paths = OrderedUnion(
        GlobalTemplates(config.global_prompts_dir),
        ProjectTemplates(config.project_prompts_dir),
        PackageTemplates(),                             -- prompts/ dirs or pi.prompts in package.json
        SettingsTemplates(),                             -- prompts array in settings
        CliTemplates()                                   -- --prompt-template <path> flags
    )

    ensures:
        for path in paths:
            let name = path.stem                         -- filename without .md
            if not exists PromptTemplate{name: name}:
                let parsed = TemplateParsed(path)
                PromptTemplate.created(
                    name: name,
                    description: parsed.description,
                    content: parsed.content,
                    source: path.source,
                    filePath: path.absolute
                )
}

rule TemplatesDisabledByFlag {
    -- --no-prompt-templates suppresses all discovery.
    when: TemplatesDiscovered(sources)

    requires: sources.noPromptTemplates = true

    ensures: no PromptTemplate.created
}

------------------------------------------------------------
-- Parsing
------------------------------------------------------------

rule TemplateParsed {
    -- Extracts frontmatter and body from a .md file.
    when: TemplateParsed(path)

    let raw = ReadFile(path)
    let frontmatter = ExtractYamlFrontmatter(raw)       -- between --- fences, or empty
    let body = raw.afterFrontmatter.trim

    ensures: result.content = body
    ensures: result.description =
        if frontmatter.description != null:
            frontmatter.description
        else:
            body.firstNonEmptyLine
}

------------------------------------------------------------
-- Argument Expansion
------------------------------------------------------------

rule ArgumentsParsed {
    -- User input after the /name is split into positional args.
    -- Quoted strings are single args; unquoted words are individual args.
    when: ArgumentsParsed(input)

    -- "Button" "click handler" → ["Button", "click handler"]
    -- Button click handler     → ["Button", "click", "handler"]

    ensures: result = ShellLikeTokenize(input)
}

rule PlaceholdersExpanded {
    -- Substitutes placeholders in template content with parsed arguments.
    when: PlaceholdersExpanded(template, args)

    ensures: result = template.content
        .replace($1, args[1])                           -- positional
        .replace($2, args[2])
        -- ...for each $N
        .replace($@, args.joinAll(" "))                  -- all args joined
        .replace($ARGUMENTS, args.joinAll(" "))          -- alias for $@
        .replaceSlice(${@:N}, args.from(N).joinAll(" "))          -- from Nth
        .replaceSlice(${@:N:L}, args.from(N).take(L).joinAll(" ")) -- L args from Nth

    -- Unreferenced placeholders are left as-is (no error).
    -- Missing args produce empty string for that placeholder.
}

------------------------------------------------------------
-- Invocation
------------------------------------------------------------

rule PromptTemplateInvoked {
    -- /name args → expand template and return as user prompt text.
    when: PromptTemplateInvoked(text)

    requires: text.startsWith("/")
    requires: exists PromptTemplate{name: text.commandName}
    -- Guard: not a registered extension command (commands take priority)

    let template = PromptTemplate{name: text.commandName}
    let args = ArgumentsParsed(text.afterCommand)

    ensures: result = ExpandedPrompt {
        content: PlaceholdersExpanded(template, args),
        source_template: template.name
    }
}

rule PromptTemplateNotFound {
    -- /name where no template or command matches.
    when: PromptTemplateInvoked(text)

    requires: text.startsWith("/")
    requires: not exists PromptTemplate{name: text.commandName}
    requires: not exists RegisteredCommand{name: text.commandName}

    ensures: result = text                              -- pass through unchanged
}

------------------------------------------------------------
-- Collision Policy
------------------------------------------------------------

rule TemplateNameCollision {
    -- When two files produce the same template name, first-discovered wins.
    -- No warning is emitted (silent shadow).
    when: PromptTemplate.created(name: name)

    requires: exists PromptTemplate{name: name}

    ensures: PromptTemplate.created is rejected          -- first one stands
}

rule CommandTakesPriority {
    -- Extension commands shadow templates with the same name.
    when: PromptTemplateInvoked(text)

    requires: exists RegisteredCommand{name: text.commandName}

    ensures: result = CommandDispatched(text)             -- template is bypassed
}

------------------------------------------------------------
-- Surface
------------------------------------------------------------

actor User {
    identified_by: HumanOperator
}

surface PromptTemplateApi {
    -- Autocomplete and invocation surface for the editor.
    for caller: User

    exposes:
        PromptTemplate.name
        PromptTemplate.description
        PromptTemplate.source

    provides:
        PromptTemplateInvoked(caller, text)
        TemplatesDiscovered(caller, sources)

    guidance:
        -- Autocomplete lists all template names with descriptions.
        -- Templates are invoked by typing /name followed by arguments.
        -- Extension commands with the same name take priority over templates.
        -- Discovery is non-recursive within prompts/ directories.
        -- Add subdirectory templates explicitly via settings or package manifest.
}

------------------------------------------------------------
-- Deferred Specifications
------------------------------------------------------------

deferred ShellLikeTokenize.parse        -- quoted-string-aware argument splitting
deferred ExtractYamlFrontmatter.parse   -- YAML frontmatter extraction between --- fences

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open_question "Should template name collisions emit a warning? Currently silent (first-discovered wins)."

open_question "Should templates support conditional sections or loops, or stay purely positional substitution?"

open_question "Should $N for missing args produce empty string, or should it be configurable (empty | error | leave-placeholder)?"
