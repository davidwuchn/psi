-- allium: 2

value ContextId { value: String }
value SessionId { value: String }
value MessageId { value: String }
value WorktreePath { value: String }
value ProjectId { value: String }
value Timestamp { value: String }
value ToolName { value: String }
value JsonMap { value: Any }

value CacheBreakpoint {
    value: system | tools
}

external entity Project {
    id: ProjectId
    git_origin_url: String?
    local_url: String
}

external entity GitWorktree {
    path: WorktreePath
    project_id: ProjectId
    branch: String?
    head_sha: String?
}

entity AgentContext {
    id: ContextId
    project_id: ProjectId
    worktree_path: WorktreePath

    baseline_system_prompt: String
    available_tools: Set<ToolName>
    available_prompt_templates: Set<String>
    available_skills: Set<String>
    loaded_extensions: Set<String>

    active_session_id: SessionId?
    status: active | closed
}

entity AgentSession {
    id: SessionId
    context_id: ContextId
    parent_session_id: SessionId?
    project_id: ProjectId
    worktree_path: WorktreePath

    effective_system_prompt: String
    cache_breakpoints: Set<CacheBreakpoint>
    active_tools: Set<ToolName>

    start_instant: Timestamp
    ended_at: Timestamp?

    name: String?
    summary_line: String?

    streaming_state: idle | streaming_assistant | streaming_tool
    status: active | paused | completed | failed

    is_root: parent_session_id = null
    has_parent: parent_session_id != null
}

entity SessionMessage {
    id: MessageId
    session: SessionId
    parent_message_id: MessageId?
    timestamp: Timestamp
    sequence_no: Integer

    role: user | assistant | tool | system | extension
    content: String?
    metadata: JsonMap?

    tool_name: ToolName?
    tool_call_id: String?
}

entity SessionContainment {
    context_id: ContextId
    parent_session_id: SessionId
    child_session_id: SessionId
    relation: fork | fork_at_entry | subagent | automation
    created_at: Timestamp
}

rule ContextInitializedExplicitly {
    when: ContextInitializeRequested(project_id, worktree_path, baseline_system_prompt)

    requires: not exists c in AgentContexts where c.project_id = project_id and c.worktree_path = worktree_path

    ensures: AgentContext.created(
        id: context_id_for(project_id, worktree_path),
        project_id: project_id,
        worktree_path: worktree_path,
        baseline_system_prompt: baseline_system_prompt,
        available_tools: {},
        available_prompt_templates: {},
        available_skills: {},
        loaded_extensions: {},
        active_session_id: null,
        status: active
    )
}

rule RootSessionCreatedInContext {
    when: SessionCreateRequested(project_id, worktree_path, system_prompt, name)

    ensures: AgentSession.created(
        id: new_session_id(),
        context_id: context_id_for(project_id, worktree_path),
        parent_session_id: null,
        project_id: project_id,
        worktree_path: worktree_path,
        effective_system_prompt: ComposeSessionPromptFromContext(
            context_id: context_id_for(project_id, worktree_path),
            requested_system_prompt: system_prompt,
            parent_session_id: null
        ),
        cache_breakpoints: {system},
        active_tools: context_tools_for(context_id_for(project_id, worktree_path)),
        start_instant: now,
        ended_at: null,
        name: name,
        summary_line: null,
        streaming_state: idle,
        status: active
    )
}

rule SpawnedSessionInheritsCacheBreakpointPolicy {
    when: SessionSpawnedFromParent(child, parent, spawn_mode)
    requires: spawn_mode in {fork_head, fork_at_entry, subagent}

    ensures: child.cache_breakpoints = parent.cache_breakpoints
}

rule SessionCacheBreakpointPolicyCanBeReconfigured {
    when: SessionCacheBreakpointsSet(session_id, breakpoints)
    requires: exists s in AgentSessions where s.id = session_id

    ensures:
        for s in AgentSessions where s.id = session_id:
            s.cache_breakpoints = breakpoints

    @guidance
        -- The session owns cache-breakpoint policy. Executors materialize that
        -- policy into provider-facing conversation/tool metadata per request.
}

contract SessionCoreEql {
    create_context: (input: JsonMap) -> JsonMap
    create_session: (input: JsonMap) -> JsonMap
    set_cache_breakpoints: (session_id: SessionId, breakpoints: Set<CacheBreakpoint>) -> JsonMap

    @invariant SessionAttrs
        -- session attrs include:
        -- {:session/id :session/context-id :session/parent-id
        --  :session/project-id :session/worktree-path
        --  :session/effective-system-prompt :session/cache-breakpoints :session/active-tools}
}

actor EqlClient {
    identified_by: "client-id"
}

surface SessionCoreApi {
    facing client: EqlClient

    contracts:
        fulfils SessionCoreEql

    exposes:
        for s in AgentSessions:
            s.id
            s.context_id
            s.parent_session_id
            s.project_id
            s.worktree_path
            s.start_instant
            s.effective_system_prompt
            s.cache_breakpoints
            s.name
            s.summary_line
            s.active_tools
            s.streaming_state
            s.status

    provides:
        SessionCreateRequested(project_id, worktree_path, system_prompt, name)
        SessionCacheBreakpointsSet(session_id, breakpoints)

    @guarantee SessionOwnsPromptCachePolicy
        -- Prompt cache breakpoint policy is session state.
        -- Provider request construction reads it indirectly via executor-built conversations.
}
