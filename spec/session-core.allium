-- allium: 2
module session-core

value SessionId { value: String }
value MessageId { value: String }
value WorktreePath { value: String }
value ProjectId { value: String }
value Timestamp { value: String }
value ToolName { value: String }
value JsonMap { value: Any }

external entity Project {
    id: ProjectId
    git_origin_url: String?
    local_url: String
}

external entity GitWorktree {
    path: WorktreePath
    project_id: ProjectId
    branch: String?
    head_sha: String?
}

entity AgentSession {
    id: SessionId
    parent_session_id: SessionId?
    project_id: ProjectId
    worktree_path: WorktreePath

    system_prompt: String
    start_instant: Timestamp
    ended_at: Timestamp?

    name: String?
    summary_line: String?

    active_tools: Set<ToolName>

    streaming_state: idle | streaming_assistant | streaming_tool
    status: active | paused | completed | failed

    is_root: parent_session_id = null
    has_parent: parent_session_id != null
}

entity SessionMessage {
    id: MessageId
    session: SessionId
    parent_message_id: MessageId?
    timestamp: Timestamp
    sequence_no: Integer

    role: user | assistant | tool | system | extension
    content: String?
    metadata: JsonMap?

    tool_name: ToolName?
    tool_call_id: String?
}

entity SessionContainment {
    parent_session_id: SessionId
    child_session_id: SessionId
    relation: fork | fork_at_entry | subagent
    created_at: Timestamp
}

entity SessionHost {
    id: String
    project_id: ProjectId
    worktree_path: WorktreePath
    active_session_id: SessionId?
}

rule SessionHostInitialized {
    when: SessionHostInitialized(project_id, worktree_path)

    ensures: SessionHost.created(
        id: host_id_for(project_id, worktree_path),
        project_id: project_id,
        worktree_path: worktree_path,
        active_session_id: null
    )
}

rule SessionCreated {
    when: SessionCreateRequested(project_id, worktree_path, system_prompt, name)

    ensures: AgentSession.created(
        id: new_session_id(),
        parent_session_id: null,
        project_id: project_id,
        worktree_path: worktree_path,
        system_prompt: system_prompt,
        start_instant: now,
        ended_at: null,
        name: name,
        summary_line: null,
        active_tools: {},
        streaming_state: idle,
        status: active
    )

    ensures:
        for h in SessionHosts where h.project_id = project_id and h.worktree_path = worktree_path:
            h.active_session_id = created_session_id()
}

rule SessionForked {
    when: SessionForkRequested(parent_session_id, worktree_path, system_prompt, name)
    requires: exists p in AgentSessions where p.id = parent_session_id and p.status = active

    ensures: AgentSession.created(
        id: new_session_id(),
        parent_session_id: parent_session_id,
        project_id: project_id_for(parent_session_id),
        worktree_path: worktree_path,
        system_prompt: system_prompt,
        start_instant: now,
        ended_at: null,
        name: name,
        summary_line: null,
        active_tools: active_tools_for(parent_session_id),
        streaming_state: idle,
        status: active
    )

    ensures: SessionContainment.created(
        parent_session_id: parent_session_id,
        child_session_id: child_session_id,
        relation: fork,
        created_at: now
    )

    ensures:
        for h in SessionHosts where h.project_id = project_id_for(parent_session_id) and h.worktree_path = worktree_path:
            h.active_session_id = child_session_id
}

rule SubagentSessionCreated {
    when: SubagentSessionRequested(parent_session_id, system_prompt, name)
    requires: exists p in AgentSessions where p.id = parent_session_id and p.status = active

    ensures: AgentSession.created(
        id: new_session_id(),
        parent_session_id: parent_session_id,
        project_id: project_id_for(parent_session_id),
        worktree_path: worktree_path_for(parent_session_id),
        system_prompt: system_prompt,
        start_instant: now,
        ended_at: null,
        name: name,
        summary_line: null,
        active_tools: active_tools_for(parent_session_id),
        streaming_state: idle,
        status: active
    )

    ensures: SessionContainment.created(
        parent_session_id: parent_session_id,
        child_session_id: child_session_id,
        relation: subagent,
        created_at: now
    )

    ensures:
        for h in SessionHosts where h.project_id = project_id_for(parent_session_id) and h.worktree_path = worktree_path_for(parent_session_id):
            h.active_session_id = child_session_id
}

rule MessageAppended {
    when: SessionMessageAppendRequested(session, role, content, metadata, tool_name, tool_call_id)
    requires: exists s in AgentSessions where s.id = session and s.status = active

    ensures: SessionMessage.created(
        id: new_message_id(),
        session: session,
        parent_message_id: last_message_id_for(session),
        timestamp: now,
        sequence_no: next_sequence_no_for(session),
        role: role,
        content: content,
        metadata: metadata,
        tool_name: tool_name,
        tool_call_id: tool_call_id
    )
}

rule AssistantStreamStarted {
    when: AssistantStreamStarted(id)
    requires: exists s in AgentSessions where s.id = id and s.status = active
    ensures:
        for s in AgentSessions where s.id = id:
            s.streaming_state = streaming_assistant
}

rule AssistantStreamCompleted {
    when: AssistantStreamCompleted(id)
    requires: exists s in AgentSessions where s.id = id and s.status = active
    ensures:
        for s in AgentSessions where s.id = id:
            s.streaming_state = idle
}

rule SessionSummaryUpdated {
    when: SessionSummaryRequested(id)
    requires: exists s in AgentSessions where s.id = id
    ensures:
        for s in AgentSessions where s.id = id:
            s.summary_line = SummarizeSessionLine(id)
}

rule ActiveSessionSwitched {
    when: SessionSwitchRequested(project_id, worktree_path, session_id)
    requires: exists s in AgentSessions where s.id = session_id and s.project_id = project_id and s.worktree_path = worktree_path

    ensures:
        for h in SessionHosts where h.project_id = project_id and h.worktree_path = worktree_path:
            h.active_session_id = session_id

    ensures:
        for r in AgentSessions where r.project_id = project_id and r.worktree_path = worktree_path and r.id != session_id:
            r.streaming_state = r.streaming_state
}

rule SessionCompleted {
    when: SessionCompletionRequested(id)
    requires: exists s in AgentSessions where s.id = id and s.status = active
    ensures:
        for s in AgentSessions where s.id = id:
            s.status = completed
    ensures:
        for s in AgentSessions where s.id = id:
            s.ended_at = now
    ensures:
        for s in AgentSessions where s.id = id:
            s.streaming_state = idle
}

invariant ParentSessionExists {
    for s in AgentSessions:
        (s.parent_session_id = null) or exists p in AgentSessions where p.id = s.parent_session_id
}

invariant SessionHasStableProject {
    for s in AgentSessions:
        exists p in Projects where p.id = s.project_id
}

invariant ActiveSessionBelongsToHost {
    for h in SessionHosts:
        (h.active_session_id = null) or
        exists s in AgentSessions where s.id = h.active_session_id and s.project_id = h.project_id and s.worktree_path = h.worktree_path
}

invariant ParentSessionIsImmutable {
    for s in AgentSessions:
        ParentSessionIdNeverChangesAfterCreate(s.id)
}

contract SessionCoreEql {
    create_session: (input: JsonMap) -> JsonMap
    fork_session: (input: JsonMap) -> JsonMap
    create_subagent_session: (input: JsonMap) -> JsonMap
    append_message: (input: JsonMap) -> JsonMap
    session_lineage: (id: SessionId) -> JsonMap
    list_sessions: (project_id: ProjectId, worktree_path: WorktreePath) -> JsonMap
    switch_session: (project_id: ProjectId, worktree_path: WorktreePath, session_id: SessionId) -> JsonMap
    extension_create_session: (session_name: String?, worktree_path: WorktreePath?, system_prompt: String?, thinking_level: String?) -> JsonMap
    extension_switch_session: (session_id: SessionId) -> JsonMap

    @invariant SessionIdentityAttrs
        -- session attrs include:
        -- {:session/id :session/parent-id :session/project-id :session/worktree-path :session/start-instant}

    @invariant SessionPromptAndSummaryAttrs
        -- session attrs include:
        -- {:session/system-prompt :session/name :session/summary-line}

    @invariant SessionMessageAttrs
        -- message attrs include:
        -- {:session.message/id :session.message/session :session.message/role :session.message/content :session.message/sequence-no}

    @invariant SessionContainmentAttrs
        -- lineage attrs include:
        -- {:session/children [{:session/id :session/relation}]}

    @invariant SessionHostAttrs
        -- host attrs include:
        -- {:session.host/id :session.host/project-id :session.host/worktree-path :session.host/active-session-id}

    @invariant SessionListAndSwitchAttrs
        -- list/switch attrs include:
        -- {:session/list [{:session/id :session/name :session/status :session/streaming-state}]
        --  :session/active-id}

    @invariant ExtensionCreateSessionAttrs
        -- extension create-session attrs include:
        -- {:psi.agent-session/session-id :psi.agent-session/session-name
        --  :psi.agent-session/cwd :psi.agent-session/thinking-level}

    @invariant ExtensionSwitchSessionAttrs
        -- extension switch-session attrs include:
        -- {:psi.agent-session/session-id :psi.agent-session/session-name
        --  :psi.agent-session/cwd}
}

actor EqlClient {
    identified_by: "client-id"
}

surface SessionCoreApi {
    facing client: EqlClient

    contracts:
        fulfils SessionCoreEql

    exposes:
        for s in AgentSessions:
            s.id
            s.parent_session_id
            s.project_id
            s.worktree_path
            s.start_instant
            s.system_prompt
            s.name
            s.summary_line
            s.active_tools
            s.streaming_state
            s.status

    provides:
        SessionHostInitialized(project_id, worktree_path)
        SessionCreateRequested(project_id, worktree_path, system_prompt, name)
        SessionForkRequested(parent_session_id, worktree_path, system_prompt, name)
        SubagentSessionRequested(parent_session_id, system_prompt, name)
        SessionSwitchRequested(project_id, worktree_path, session_id)
        ExtensionSessionCreateRequested(session_name, worktree_path, system_prompt, thinking_level)
        ExtensionSessionSwitchRequested(session_id)
        SessionMessageAppendRequested(session, role, content, metadata, tool_name, tool_call_id)
        AssistantStreamStarted(id)
        AssistantStreamCompleted(id)
        SessionSummaryRequested(id)
        SessionCompletionRequested(id)

    @guarantee SessionRunsInWorktreeContext
        -- Every session is bound to a project and a git worktree path.

    @guarantee SessionCanContainSessions
        -- Fork and subagent relations are represented as explicit parent-child containment.

    @guarantee ActiveSessionRoutesByDefault
        -- Prompts/mutations without explicit session id route to the host active session.

    @guarantee SessionSwitchDoesNotInterruptOthers
        -- Switching active session does not force non-target sessions to idle.
        -- In-flight runs in non-target sessions continue.

    @guarantee ExtensionSessionMutationsReuseCoreLifecycle
        -- Extension-facing session create/switch mutations are thin wrappers over
        -- the same core session lifecycle semantics.
        -- create-session creates a distinct host peer session and makes it active.
        -- switch-session routes to a resumable host session by id and makes it active.
}

open question "Should SessionMessage.content allow structured multimodal content in addition to String?"
open question "Should system and extension messages be persisted in the same stream as user/assistant/tool messages?"
-- Decision: forked sessions inherit parent system prompt by default.
