-- allium: 2

value ContextId { value: String }
value SessionId { value: String }
value MessageId { value: String }
value WorktreePath { value: String }
value ProjectId { value: String }
value Timestamp { value: String }
value ToolName { value: String }
value JsonMap { value: Any }

value CacheBreakpoint {
    value: system | tools
}

value PromptMode {
    value: lambda | prose
}

external entity Project {
    id: ProjectId
    git_origin_url: String?
    local_url: String
}

external entity GitWorktree {
    path: WorktreePath
    project_id: ProjectId
    branch: String?
    head_sha: String?
}

entity AgentContext {
    id: ContextId
    project_id: ProjectId
    worktree_path: WorktreePath

    baseline_system_prompt: String
    available_tools: Set<ToolName>
    available_prompt_templates: Set<String>
    available_skills: Set<String>
    loaded_extensions: Set<String>

    status: active | closed

    @guidance
        -- active_session_id is NOT owned by AgentContext.
        -- Selection of which session is currently focused is a UI/adapter concern
        -- (TUI, RPC, Emacs). The core manages sessions by SessionId only.
        -- Adapters maintain their own focus pointer and pass session_id explicitly
        -- on every operation.
}

entity AgentSession {
    id: SessionId
    context_id: ContextId
    parent_session_id: SessionId?
    project_id: ProjectId
    worktree_path: WorktreePath

    effective_system_prompt: String
    prompt_mode: PromptMode
    cache_breakpoints: Set<CacheBreakpoint>
    active_tools: Set<ToolName>

    start_instant: Timestamp
    ended_at: Timestamp?

    name: String?
    summary_line: String?

    streaming_state: idle | streaming_assistant | streaming_tool
    status: active | paused | completed | failed

    -- Per-session runtime handles, stored in canonical state
    agent_core: Any
    statechart_session_id: String

    is_root: parent_session_id = null
    has_parent: parent_session_id != null
}

entity SessionMessage {
    id: MessageId
    session: SessionId
    parent_message_id: MessageId?
    timestamp: Timestamp
    sequence_no: Integer

    role: user | assistant | tool | system | extension
    content: String?
    metadata: JsonMap?

    tool_name: ToolName?
    tool_call_id: String?
}

entity SessionContainment {
    context_id: ContextId
    parent_session_id: SessionId
    child_session_id: SessionId
    relation: fork | fork_at_entry | agent | automation
    created_at: Timestamp
}

entity ExtensionInstanceState {
    context_id: ContextId
    extension_name: String
    instance_id: String
    data: JsonMap

    @guidance
        -- Opaque per-invocation state owned by an extension.
        -- Core stores and exposes it via EQL; extensions own the shape.
        -- Keyed by [extension_name, instance_id] within a context.
        -- Examples:
        --   ["agent", "agent-7"]        → steering/follow-up/interrupt state
        --   ["agent-chain", "run-3"]    → step sessions, accumulated input, progress
}

rule ContextInitializedExplicitly {
    when: ContextInitializeRequested(project_id, worktree_path, baseline_system_prompt)

    requires: not exists c in AgentContexts where c.project_id = project_id and c.worktree_path = worktree_path

    ensures: AgentContext.created(
        id: context_id_for(project_id, worktree_path),
        project_id: project_id,
        worktree_path: worktree_path,
        baseline_system_prompt: baseline_system_prompt,
        available_tools: {},
        available_prompt_templates: {},
        available_skills: {},
        loaded_extensions: {},
        status: active
    )
}

rule RootSessionCreatedInContext {
    when: SessionCreateRequested(project_id, worktree_path, system_prompt, name)

    ensures: AgentSession.created(
        id: new_session_id(),
        context_id: context_id_for(project_id, worktree_path),
        parent_session_id: null,
        project_id: project_id,
        worktree_path: worktree_path,
        effective_system_prompt: ComposeSessionPromptFromContext(
            context_id: context_id_for(project_id, worktree_path),
            requested_system_prompt: system_prompt,
            parent_session_id: null,
            prompt_mode: lambda_mode/ResolvePromptMode(new_session_id()).effective_mode
        ),
        prompt_mode: lambda_mode/ResolvePromptMode(new_session_id()).effective_mode,
        cache_breakpoints: {system},
        active_tools: context_tools_for(context_id_for(project_id, worktree_path)),
        start_instant: now,
        ended_at: null,
        name: name,
        summary_line: null,
        streaming_state: idle,
        status: active,
        agent_core: NewAgentCore(),
        statechart_session_id: NewStatechartSessionId()
    )
}

rule SessionCreationDoesNotDisturbSiblings {
    when: SessionCreateRequested(project_id, worktree_path, system_prompt, name)
    requires: exists ctx in AgentContexts where ctx.project_id = project_id

    ensures:
        for s in AgentSessions where s.context_id = ctx.id and s.status = active:
            s.streaming_state = unchanged
            s.agent_core = unchanged

    @guidance
        -- Creating a new session has no effect on existing sessions in the
        -- same context. Each session's runtime handles are independent.
}

rule SpawnedSessionInheritsCacheBreakpointPolicy {
    when: SessionSpawnedFromParent(child, parent, spawn_mode)
    requires: spawn_mode in {fork_head, fork_at_entry, agent}

    ensures: child.cache_breakpoints = parent.cache_breakpoints
}

rule SpawnedSessionInheritsPromptMode {
    when: SessionSpawnedFromParent(child, parent, spawn_mode)
    requires: spawn_mode in {fork_head, fork_at_entry, agent}

    ensures: child.prompt_mode = parent.prompt_mode
}

rule SessionCacheBreakpointPolicyCanBeReconfigured {
    when: SessionCacheBreakpointsSet(session_id, breakpoints)
    requires: exists s in AgentSessions where s.id = session_id

    ensures:
        for s in AgentSessions where s.id = session_id:
            s.cache_breakpoints = breakpoints

    @guidance
        -- The session owns cache-breakpoint policy. Executors materialize that
        -- policy into provider-facing conversation/tool metadata per request.
}

contract SessionCoreEql {
    create_context: (input: JsonMap) -> JsonMap
    create_session: (input: JsonMap) -> JsonMap
    set_cache_breakpoints: (session_id: SessionId, breakpoints: Set<CacheBreakpoint>) -> JsonMap
    set_prompt_mode: (session_id: SessionId, mode: PromptMode) -> JsonMap

    @invariant SessionAttrs
        -- session attrs include:
        -- {:session/id :session/context-id :session/parent-id
        --  :session/project-id :session/worktree-path
        --  :session/effective-system-prompt :session/prompt-mode
        --  :session/cache-breakpoints :session/active-tools}
}

actor EqlClient {
    identified_by: "client-id"
}

use "./system-context-unification.allium" as system_ctx
use "./lambda-mode.allium" as lambda_mode

surface SessionCoreApi {
    facing client: EqlClient

    contracts:
        fulfils SessionCoreEql

    exposes:
        for s in AgentSessions:
            s.id
            s.context_id
            s.parent_session_id
            s.project_id
            s.worktree_path
            s.start_instant
            s.effective_system_prompt
            s.prompt_mode
            s.cache_breakpoints
            s.name
            s.summary_line
            s.active_tools
            s.streaming_state
            s.status

    provides:
        SessionCreateRequested(project_id, worktree_path, system_prompt, name)
        CreateChildSession(context_id, parent_session_id, relation, config)
        RunAgentLoopInSession(session_id, prompt, model)
        SessionCacheBreakpointsSet(session_id, breakpoints)
        ExtensionInstanceStateSet(context_id, extension_name, instance_id, data)
        ExtensionInstanceStateGet(context_id, extension_name, instance_id)
        lambda_mode/SetSessionPromptMode(session_id, mode)

    @guarantee SessionOwnsPromptCachePolicy
        -- Prompt cache breakpoint policy is session state.
        -- Provider request construction reads it indirectly via executor-built conversations.

    @guarantee ContextOwnsSharedResources
        -- Tools, prompt templates, skills, and extensions are loaded onto the context.
        -- Sessions use these shared resources; they do not own independent copies.

    @guarantee SessionsFormATreeWithinContext
        -- Every forked or agent session is represented as a child session in the same context.

    @guarantee AgentIsASession
        -- An agent is modeled as just another session in the context tree.
        -- The distinction is recorded by SessionContainment.relation = agent.

    @guarantee SessionStartInstantIsStableForUiProjection
        -- Every session has a start_instant fixed at creation time.
        -- UI projections may expose this timestamp so clients can render relative age
        -- without losing the canonical underlying value.

    @guarantee ActiveSessionSelectionBelongsToAdapters
        -- There is no active_session_id in the core.
        -- Session focus/selection is owned by each adapter (TUI, RPC, Emacs).
        -- Every core operation takes an explicit session_id.
        -- Switching focus in a UI does not affect any other adapter or the core.

    @guarantee ConcurrentSessionExecution
        -- Multiple sessions within a context may execute concurrently.
        -- Each session owns its own agent_core and statechart_session_id.
        -- Concurrent sessions share process-scoped resources (extensions, registries,
        -- config) but do not share per-session runtime handles or mutable session state.

    @guarantee SessionIdIsTheRoutingHandle
        -- Consumers (TUI, extensions, RPC) address sessions by SessionId only.
        -- They do not hold or receive the process-scoped runtime context.
        -- All operations route through a service surface parameterized by SessionId.

    @guarantee SessionRunsInWorktreeContext
        -- Every context is bound to exactly one project/worktree pair.
        -- All sessions inside that context inherit that project/worktree binding.

    @guarantee ContextIsCanonicalSystemContextProjection
        -- AgentContext is the session-core projection of the canonical system context.
        -- Shared mutable runtime state is rooted in system_ctx/SystemContext rather than in multiple independent mutable roots.

    @guarantee ExtensionInstanceStateIsOpaqueToCore
        -- Core stores, queries, and garbage-collects ExtensionInstanceState.
        -- Core does not interpret or validate the data map.
        -- Extensions own the shape and enforce their own schema.
        -- Queryable via EQL by [extension_name, instance_id].
}
