-- allium: 1

-- coding-agent.allium
-- High-level coding-agent orchestration contract.

use "./agent.allium" as agent
use "./session-management.allium" as session
use "./skills.allium" as skills
use "./prompt-templates.allium" as templates
use "./extension-system.allium" as ext
use "./oauth-auth.allium" as auth
use "./default-footer.allium" as footer
use "./compaction.allium" as compact
use "./tools.allium" as tools
use "./project-preferences.allium" as prefs

entity CodingAgentRuntime {
    session: session/AgentSession
    started: Boolean
    ui_type: console | tui | emacs | rpc
}

rule RuntimeStarted {
    when: RuntimeStarted(runtime)

    ensures: runtime.started = true
    ensures: session/NewSessionStarted(runtime.session, input: null)
}

rule PromptSubmissionFromIdle {
    when: PromptSubmitted(runtime, text, images)

    requires: runtime.session.is_idle
    requires: runtime.session.model != null

    ensures: session/UserPrompts(runtime.session, text, images)
}

rule PromptSubmissionWhileStreaming {
    when: PromptSubmitted(runtime, text, images)
    requires: runtime.session.is_streaming

    ensures: session/UserPromptsWhileStreaming(runtime.session, text, behavior: follow_up)
}

rule SlashCommandSubmission {
    when: PromptSubmitted(runtime, text, images)
    requires: StartsWith(text, "/")

    ensures: SlashDispatchRequested(runtime.session, text)
}

rule SkillsAndTemplatesAvailable {
    when: RuntimeStarted(runtime)

    ensures: skills/SkillsDiscoveryRequested(sources: RuntimeSkillSources(runtime))
    ensures: templates/TemplateDiscoveryRequested(sources: RuntimeTemplateSources(runtime))
}

rule ExtensionsLoaded {
    when: RuntimeStarted(runtime)

    ensures: ext/ExtensionsLoaded(runtime.session, ExtensionPaths(runtime))
}

rule ActiveToolsInitialized {
    when: RuntimeStarted(runtime)

    ensures: runtime.session.active_tools = tools/DefaultActiveToolSet()
}

rule FooterProjectionUpdated {
    when: SessionChanged(runtime.session)

    ensures: footer/FooterRenderRequested(CurrentFooter(runtime), width: CurrentViewportWidth(runtime))
}

rule AuthenticationRequiredBeforeRun {
    when: PromptSubmitted(runtime, text, images)

    requires: runtime.session.model != null
    requires: auth/HasAuthChecked(CurrentCredentialStore(runtime), runtime.session.model.provider)

    ensures: PromptAuthorizationSatisfied(runtime)
}

rule ProjectPreferencesAppliedOnStartup {
    when: RuntimeStarted(runtime)

    ensures: prefs/BootstrapReadsProjectPreferences(runtime.session)
    ensures: prefs/BootstrapAppliesPersistedThinkingLevelWithClamping(runtime.session)
}

surface CodingAgentApi {
    facing caller: session/User

    context runtime: CodingAgentRuntime

    exposes:
        runtime.started
        runtime.ui_type
        runtime.session

    provides:
        RuntimeStarted(runtime)
        PromptSubmitted(runtime, text, images)
        SessionChanged(runtime.session)

    related:
        session/AgentSessionApi
        agent/AgentApi
        ext/ExtensionApi
        auth/CredentialStoreApi
        footer/DefaultFooterView
}

open question "Should prompt submission while streaming default to steer or follow_up by ui_type?"
