-- allium: 2

-- coding-agent.allium
-- High-level coding-agent orchestration contract.

use "./agent.allium" as agent
use "./session-management.allium" as session
use "./session-core.allium" as core
use "./skills.allium" as skills
use "./prompt-templates.allium" as templates
use "./extension-system.allium" as ext
use "./oauth-auth.allium" as auth
use "./default-footer.allium" as footer
use "./compaction.allium" as compact
use "./tools.allium" as tools
use "./project-preferences.allium" as prefs
use "./system-context-unification.allium" as system_ctx

entity CodingAgentRuntime {
    context: core/AgentContext
    started: Boolean
    ui_type: console | tui | emacs | rpc
}

rule RuntimeStarted {
    when: RuntimeStarted(runtime)

    ensures: runtime.started = true
    ensures: skills/SkillsDiscoveryRequested(sources: RuntimeSkillSources(runtime))
    ensures: templates/TemplateDiscoveryRequested(sources: RuntimeTemplateSources(runtime))
    ensures: ext/ExtensionsLoaded(runtime.context, ExtensionPaths(runtime))
    ensures: core/ContextResourcesRegistered(
        context_id: runtime.context.id,
        tools: tools/DefaultActiveToolSet(),
        prompt_templates: DiscoveredTemplateNames(runtime),
        skills: DiscoveredSkillNames(runtime),
        extensions: LoadedExtensionPaths(runtime)
    )
}

rule RuntimeCreatesRootSessionOnDemand {
    when: StartRootSessionRequested(runtime, name)
    requires: runtime.started = true

    ensures: session/NewSessionStarted(RootSessionFor(runtime.context, name), input: {
        project_id: runtime.context.project_id,
        worktree_path: runtime.context.worktree_path,
        spawn_mode: new_root
    })
}

rule PromptSubmissionFromIdle {
    when: PromptSubmitted(runtime, text, images, session_id)
    requires: SessionForPrompt(runtime.context, session_id).is_idle
    requires: SessionForPrompt(runtime.context, session_id).model != null

    ensures: session/UserPrompts(SessionForPrompt(runtime.context, session_id), text, images)
}

rule PromptSubmissionWhileStreaming {
    when: PromptSubmitted(runtime, text, images, session_id)
    requires: SessionForPrompt(runtime.context, session_id).is_streaming

    ensures: session/UserPromptsWhileStreaming(SessionForPrompt(runtime.context, session_id), text, behavior: follow_up)
}

rule SlashCommandSubmission {
    when: PromptSubmitted(runtime, text, images, session_id)
    requires: StartsWith(text, "/")

    ensures: SlashDispatchRequested(SessionForPrompt(runtime.context, session_id), text)
}

rule ActiveToolsDerivedFromContext {
    when: RuntimeStarted(runtime)

    ensures: runtime.context.available_tools = tools/DefaultActiveToolSet()
}

rule FooterProjectionUpdated {
    when: SessionChanged(runtime.context, session_id)

    ensures: footer/FooterRenderRequested(CurrentFooter(runtime), width: CurrentViewportWidth(runtime))
}

rule AuthenticationRequiredBeforeRun {
    when: PromptSubmitted(runtime, text, images, session_id)

    requires: SessionForPrompt(runtime.context, session_id).model != null
    requires: auth/HasAuthChecked(CurrentCredentialStore(runtime), SessionForPrompt(runtime.context, session_id).model.provider)

    ensures: PromptAuthorizationSatisfied(runtime)
}

rule ProjectPreferencesAppliedOnContextStartup {
    when: RuntimeStarted(runtime)

    ensures: prefs/BootstrapReadsProjectPreferences(runtime.context)
}

rule ProjectPreferencesAppliedToSessionOnCreate {
    when: StartRootSessionRequested(runtime, name)

    ensures: prefs/BootstrapAppliesPersistedThinkingLevelWithClamping(RootSessionFor(runtime.context, name))
}

surface CodingAgentApi {
    facing caller: session/User

    context runtime: CodingAgentRuntime

    exposes:
        runtime.started
        runtime.ui_type
        runtime.context

    provides:
        RuntimeStarted(runtime)
        StartRootSessionRequested(runtime, name)
        PromptSubmitted(runtime, text, images, session_id)
        SessionChanged(runtime.context, session_id)

    related:
        session/AgentSessionApi
        core/SessionCoreApi
        agent/AgentApi
        ext/ExtensionApi
        auth/CredentialStoreApi
        footer/DefaultFooterView

    @guarantee RuntimeOwnsContext
        -- A runtime owns one context.
        -- The context owns shared resources and a tree of sessions.
        -- That context is implemented as the canonical mutable system context described by system_ctx/SystemContext.

    @guarantee AgentIsOperationalViewOfSession
        -- Agent execution is routed to a target session within the context.
        -- Subagents are child sessions, not a separate top-level concept.
}

open question "Should prompt submission while streaming default to steer or follow_up by ui_type?"