#kaocha/v1
{:tests
 [{:id :unit
   :test-paths ["test" "components/ai/test" "components/engine/test" "components/query/test" "components/history/test"
               "components/introspection/test" "components/tui/test" "components/agent-core/test"]
   :source-paths ["src" "components/ai/src" "components/engine/src" "components/query/src" "components/history/src"
                 "components/introspection/src" "components/tui/src" "components/agent-core/src"]
   :ns-patterns [".*-test$"]}]
 
 :color? true
 :fail-fast? false
 :capture-output? true
 
 ;; Reporters
 :reporter [kaocha.report/documentation]
 
 ;; Plugins
 :plugins []
 
 ;; Skip tests that require API keys unless environment variables are set
 :skip-meta [:integration]}
