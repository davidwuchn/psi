                                                          (:psi.turn/text . nil)
                                                          (:psi.turn/tool-calls . [])))))))
                         t)
                        (t t)))))
            (psi-emacs--handle-rpc-event
             '((:event . "command-result")
               (:data . ((:type . "session_switch")
                         (:session-id . "s-new"))))))
          (setq rpc-calls (nreverse rpc-calls))
          (should (equal '("switch_session" "get_messages" "query_eql")
