{:deps {;; Engine (∅) -> substrate: explicit, queryable state machines
        com.fulcrologic/statecharts                   {:mvn/version "1.2.25"}
        ;; Query + Graph: EQL interface to everything
        com.wsscode/pathom3                           {:mvn/version "2025.01.16-alpha"}
        ;; API: OpenAPI specs -> callable clients
        com.github.oliyh/martian-babashka-http-client {:mvn/version "0.2.1"}
        org.clojure/clojure                           {:mvn/version "1.12.4"}
        ;; Components
        psi/ai                                        {:local/root "components/ai"}
        psi/engine                                    {:local/root "components/engine"}
        psi/query                                     {:local/root "components/query"}
        psi/history                                   {:local/root "components/history"}
        psi/introspection                             {:local/root "components/introspection"}
        psi/memory                                    {:local/root "components/memory"}
        psi/tui                                       {:local/root "components/tui"}
        psi/agent-core                                {:local/root "components/agent-core"}
        psi/agent-session                             {:local/root "components/agent-session"}
        psi/recursion                                 {:local/root "components/recursion"}
        psi/ui-state                                  {:local/root "components/ui-state"}
        psi/system-bootstrap                          {:local/root "components/system-bootstrap"}}
 :aliases
 {:dev   {:extra-paths ["dev"]}
  :run   {:extra-paths ["components/agent-session/src"
                        "components/agent-core/src"
                        "components/ai/src"
                        "components/engine/src"
                        "components/query/src"]
          :extra-deps  {nrepl/nrepl {:mvn/version "1.5.1"}}
          :jvm-opts    ["--enable-native-access=ALL-UNNAMED"]
          :main-opts   ["-m" "psi.agent-session.main"]}
  :psi   {:extra-paths ["components/agent-session/src"
                        "components/agent-core/src"
                        "components/ai/src"
                        "components/engine/src"
                        "components/query/src"]
          :extra-deps  {nrepl/nrepl {:mvn/version "1.5.1"}}
          :jvm-opts    ["--enable-native-access=ALL-UNNAMED"]
          :main-opts   ["-m" "psi.agent-session.main"]}
  :nrepl {:extra-deps {nrepl/nrepl {:mvn/version "1.5.1"}}}
  :fmt   {:extra-deps {dev.weavejester/cljfmt {:mvn/version "0.13.1"}}
          :exec-fn    cljfmt.main/check
          :exec-args  {:paths ["bb.edn"
                               "deps.edn"
                               ".lsp/config.edn"
                               ".psi/startup-prompts.edn"
                               "components"
                               "extensions"
                               "spec"
                               "specs"
                               "test"
                               "tests.edn"
                               "extensions/tests.edn"]}}
  :lint  {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2025.09.19"}}
          :main-opts  ["-m"
                       "clj-kondo.main"
                       "--lint"
                       "bb.edn"
                       "deps.edn"
                       ".lsp/config.edn"
                       ".psi/startup-prompts.edn"
                       "components"
                       "extensions"
                       "spec"
                       "specs"
                       "tests.edn"
                       "extensions/tests.edn"]}
  :test  {:extra-paths ["components/ai/test"
                        "components/query/test"
                        "components/history/test"
                        "components/introspection/test"
                        "components/memory/test"
                        "components/recursion/test"
                        "components/tui/test"
                        "components/agent-core/test"
                        "components/agent-session/test"
                        "extensions/test"
                        "components/ai/src"
                        "components/engine/src"
                        "components/query/src"
                        "components/history/src"
                        "components/introspection/src"
                        "components/memory/src"
                        "components/recursion/src"
                        "components/tui/src"
                        "components/agent-core/src"
                        "components/agent-session/src"
                        "components/ui-state/src"
                        "components/system-bootstrap/src"
                        "extensions/src"
                        "components/extension-test-helpers/src"]
          :extra-deps  {lambdaisland/kaocha {:mvn/version "1.91.1392"}
                        nrepl/nrepl         {:mvn/version "1.5.1"}}
          :jvm-opts    ["--enable-native-access=ALL-UNNAMED"]
          :main-opts   ["-m" "kaocha.runner"]}
  :debug-test {:extra-paths ["test"
                             "components/ai/test"
                             "components/engine/test"
                             "components/query/test"
                             "components/history/test"
                             "components/introspection/test"
                             "components/memory/test"
                             "components/recursion/test"
                             "components/tui/test"
                             "components/agent-core/test"
                             "components/agent-session/test"]}}}
