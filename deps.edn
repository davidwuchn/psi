{:deps {;; Engine (∅) -> substrate: explicit, queryable state machines
        com.fulcrologic/statecharts                   {:mvn/version "1.2.25"}
        ;; Query + Graph: EQL interface to everything
        com.wsscode/pathom3                           {:mvn/version "2025.01.16-alpha"}
        ;; API: OpenAPI specs -> callable clients
        com.github.oliyh/martian-babashka-http-client {:mvn/version "0.2.1"}
        org.clojure/clojure                           {:mvn/version "1.12.4"}
        ;; Components
        psi/ai                                        {:local/root "components/ai"}
        psi/engine                                    {:local/root "components/engine"}
        psi/query                                     {:local/root "components/query"}
        psi/history                                   {:local/root "components/history"}
        psi/introspection                             {:local/root "components/introspection"}}
 :aliases
 {:dev   {:extra-paths ["dev"]}
  :nrepl {:extra-deps {nrepl/nrepl {:mvn/version "1.5.1"}}}
  :test  {:extra-paths ["test" "components/ai/test" "components/query/test" "components/history/test"
                        "components/introspection/test"
                        "components/ai/src" "components/engine/src" "components/query/src" "components/history/src"
                        "components/introspection/src"]
          :extra-deps  {lambdaisland/kaocha {:mvn/version "1.91.1392"}}
          :main-opts   ["-m" "kaocha.runner"]}}}
